# =============================================
# Photoview – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=photoview

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=gallery.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# photoview/photoview (https://hub.docker.com/r/photoview/photoview)
APP_TAG=2
# mariadb (https://hub.docker.com/_/mariadb)
DB_TAG=lts

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Storage ---
# Root folder containing your photos/videos. Mounted read-only into the
# container at /photos. Photoview scans it recursively.
MEDIA_ROOT=/path/to/your/photos

# --- Database ---
DB_NAME=photoview
DB_USER=photoview
# Photoview assembles the MySQL DSN inline — no _FILE support.
# IMPORTANT: the password must NOT contain special DSN characters
# (`@`, `:`, `/`, `?`, `#`). Use only [A-Za-z0-9] to be safe.
# Value must match contents of .secrets/db_pwd.txt.
DB_PWD_INLINE=__REPLACE_ME__

# --- Optional: Mapbox map view ---
# Generate a free token at https://account.mapbox.com/access-tokens/
# Leave empty to disable the map feature.
MAPBOX_TOKEN=

# --- Optional: video hardware acceleration ---
# One of: qsv, vaapi, nvenc. Leave empty to use software encoding.
# If enabled, uncomment the matching `devices:` block in docker-compose.yml.
PHOTOVIEW_VIDEO_HARDWARE_ACCELERATION=

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
