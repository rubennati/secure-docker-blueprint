# =============================================
# Cal.diy – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
#
# Cal.diy is the community edition of Cal.com (MIT). Strictly for
# personal, non-production use per upstream. If you need a
# commercial-ready scheduling backend, use apps/calcom/ instead.
# =============================================

COMPOSE_PROJECT_NAME=caldiy

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=cal.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=3000
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# IMPORTANT: verify the current upstream image path at https://cal.diy/docs/docker
# before first boot. Cal.diy publishes the MIT community edition under its
# own container image path, separate from the commercial calcom/cal.com build.
# Placeholder below — replace once verified:
APP_IMAGE=ghcr.io/caldiy/caldiy
APP_TAG=latest
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=17

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=caldiy
DB_USER=caldiy
# Prisma reads one DATABASE_URL (no _FILE support). Keep identical to
# ./.secrets/db_pwd.txt — same limitation as apps/calcom/.
DB_PWD_INLINE=__REPLACE_ME__

# --- Email / SMTP ---
EMAIL_FROM=cal@example.com
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=

# --- Timezone ---
TZ=UTC
