# =============================================
# Cal.diy – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
#
# Cal.diy is the MIT-licensed community edition of Cal.com.
# Upstream explicitly labels it as "strictly for personal,
# non-production use" with no security guarantees from Cal.com, Inc.
# =============================================

COMPOSE_PROJECT_NAME=caldiy

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=cal.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=3000
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# ghcr.io/rubennati/cal.diy (https://github.com/rubennati/cal.diy/pkgs/container/cal.diy)
# ARM: use the -arm suffixed tag (e.g. v6.2.0-arm)
APP_TAG=v6.2.0
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=17.4
# redis (https://hub.docker.com/_/redis)
REDIS_TAG=7.4-alpine

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_REDIS=${COMPOSE_PROJECT_NAME}-redis

# --- Database ---
DB_NAME=caldiy
DB_USER=caldiy

# --- App Configuration ---
# Branding — shown in the UI, support links, and page titles
NEXT_PUBLIC_APP_NAME=Cal.diy
NEXT_PUBLIC_COMPANY_NAME=Cal.diy
NEXT_PUBLIC_SUPPORT_MAIL_ADDRESS=admin@example.com

# Legal — set to your own policy pages, or leave empty
NEXT_PUBLIC_WEBSITE_PRIVACY_POLICY_URL=
NEXT_PUBLIC_WEBSITE_TERMS_URL=

# VAPID keys for push notifications — required, app errors on boot without them
# Generate: docker run --rm node:lts-alpine npx --yes web-push generate-vapid-keys
VAPID_PUBLIC_KEY=__REPLACE_ME__
VAPID_PRIVATE_KEY=__REPLACE_ME__

# Logging level (0=silly … 6=fatal; 3=info+ recommended for production)
NEXT_PUBLIC_LOGGER_LEVEL=3

# Calendar integrations — set to true and fill credentials to enable
# Google credentials guide: https://github.com/rubennati/cal.diy#obtaining-the-google-api-credentials
GOOGLE_LOGIN_ENABLED=false
GOOGLE_API_CREDENTIALS=
GOOGLE_CALENDAR_API_KEY=
OUTLOOK_LOGIN_ENABLED=false

# --- SMTP ---
EMAIL_FROM=cal@example.com
EMAIL_FROM_NAME=Cal.diy
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and generate all required files:
#   mkdir -p .secrets volumes/postgres volumes/redis
#   openssl rand -hex 32 > .secrets/db_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/nextauth_secret.txt
#   openssl rand -base64 24 | tr -d '\n' > .secrets/encryption_key.txt
#   openssl rand -hex 16 | tr -d '\n' > .secrets/cron_api_key.txt
#   touch .secrets/smtp_password.txt  # write SMTP password here if needed
