# =============================================
# BookStack – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=bookstack

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=wiki.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# linuxserver/bookstack (https://docs.linuxserver.io/images/docker-bookstack/)
APP_TAG=version-v25.02
# mariadb (https://hub.docker.com/_/mariadb)
DB_TAG=11.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- User Mapping ---
# Must match the UID/GID that owns ./volumes/config/ on the host.
PUID=1000
PGID=1000

# --- Database ---
DB_NAME=bookstack
DB_USER=bookstack
# BookStack reads DB_PASSWORD from a single env var (no _FILE support).
# Value must match the content of ./.secrets/db_pwd.txt verbatim.
# See README "Known Issues" for rationale.
DB_PWD_INLINE=__REPLACE_ME__

# --- BookStack App Key ---
# Laravel APP_KEY — encrypts sessions, cookies, and password-reset tokens.
# Generate once with:
#   docker run --rm --entrypoint /bin/bash lscr.io/linuxserver/bookstack:${APP_TAG} appkey
# Keep the "base64:" prefix in the output. Rotating invalidates sessions.
APP_KEY=__REPLACE_ME__

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
