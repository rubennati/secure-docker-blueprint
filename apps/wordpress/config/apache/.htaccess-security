# ==========================================================
# WordPress Security Hardening (.htaccess)
# ==========================================================
# Append to the END of .htaccess (after WordPress rewrite
# rules). Do NOT place inside # BEGIN/END WordPress block.
#
# Apply once after WordPress installer finishes:
#   docker compose exec app bash -c \
#     'cat /config/.htaccess-security >> /var/www/html/.htaccess'
#
# NOTE: Only .htaccess-compatible directives are used here.
# <Directory> blocks are NOT allowed in .htaccess context.
# ==========================================================

# --- Block PHP execution in uploads directory ---
# Prevents uploaded PHP shells from being executed.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^wp-content/uploads/.*\.ph(p[345s]?|tml|ar)$ - [F,L]
</IfModule>

# --- Protect sensitive files ---
<FilesMatch "^(\.htaccess|\.htpasswd|wp-config\.php|readme\.html|license\.txt)$">
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order Allow,Deny
    Deny from all
</IfModule>
</FilesMatch>

# --- Disable directory listing ---
Options -Indexes

# --- Block XML-RPC ---
<Files xmlrpc.php>
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order Allow,Deny
    Deny from all
</IfModule>
</Files>

# --- Block author enumeration ---
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{QUERY_STRING} ^author=\d+ [NC]
RewriteRule .* - [F,L]
</IfModule>
