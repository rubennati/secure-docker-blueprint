# =============================================
# UniFi Network Application – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=unifi

# --- Domain & Traefik (Web UI only — device ports are direct) ---
APP_TRAEFIK_HOST=unifi.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=8443
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# LSIO UniFi Network Application
# (https://docs.linuxserver.io/images/docker-unifi-network-application/)
APP_TAG=latest
# MongoDB — MUST stay at 4.4. UniFi does NOT support MongoDB 5+.
DB_TAG=4.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- User Mapping ---
PUID=1000
PGID=1000

# --- Database ---
DB_NAME=unifi
DB_ROOT_USER=root
DB_APP_USER=unifi-app
# UniFi's MONGO_PASS env var has no _FILE support. Value must match
# contents of .secrets/db_app_pwd.txt verbatim.
DB_APP_PWD_INLINE=__REPLACE_ME__

# --- Memory ---
# Java heap for the UniFi controller (MB). Raise for large sites:
#   - 1024 for <= 50 devices
#   - 2048 for <= 200 devices
#   - 4096 for large WISP/MSP deployments
MEM_LIMIT=1024

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
