# =============================================
# Matomo – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=matomo

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=analytics.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# matomo (https://hub.docker.com/_/matomo)
APP_TAG=5-apache
# mariadb (https://hub.docker.com/_/mariadb)
DB_TAG=11.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=matomo
DB_USER=matomo
# Table prefix — NEVER leave as "matomo_" in a shared DB. Keep "mtm_"
# or any other short prefix. Changing after first setup requires an
# in-place table rename.
DB_TABLES_PREFIX=mtm_

# --- PHP ---
# Matomo's tracking endpoint can spike memory on large batch imports.
# 256 MB is a safe default; raise to 512 MB for heavy traffic sites.
PHP_MEMORY_LIMIT=256M

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
