# =============================================
# NocoDB – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=nocodb

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=nocodb.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-tailscale
# sec-1: NocoDB loads 100+ JS chunks simultaneously on first visit — any
# rate-limit middleware (sec-2+) triggers 429 errors on initial page load.
# sec-1 still sets basic security headers; no rate-limit is acceptable
# because the app is VPN-only (acc-tailscale).
APP_TRAEFIK_SECURITY=sec-1
APP_INTERNAL_PORT=8080
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# nocodb (https://hub.docker.com/r/nocodb/nocodb)
APP_TAG=0.301.5

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- App Configuration ---
# Super-admin account created on first start (bypasses email verification).
# Password requirements: min 8 chars, uppercase letter, number, special char.
# Example: MyPass1! — use a real strong password, not this placeholder.
NC_ADMIN_EMAIL=admin@example.com
NC_ADMIN_PASSWORD=

# Signup policy:
# "true"  = only users invited by an admin can sign up (recommended)
# "false" = anyone who reaches the URL can create an account
NC_INVITE_ONLY_SIGNUP=true

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Generate JWT secret:
#   mkdir -p .secrets
#   openssl rand -base64 32 | tr -d '\n' > .secrets/nc_jwt_secret.txt
