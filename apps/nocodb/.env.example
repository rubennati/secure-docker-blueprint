# =============================================
# NocoDB – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=nocodb

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=nocodb.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=8080
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# nocodb (https://hub.docker.com/r/nocodb/nocodb)
APP_TAG=latest

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- Signup policy ---
# "true"  = only users invited by an admin can sign up (recommended)
# "false" = anyone who reaches the URL can create an account
NC_INVITE_ONLY_SIGNUP=true

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
