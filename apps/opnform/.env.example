# =============================================
# OpnForm – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=opnform

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=forms.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# jhumanj/opnform-api + jhumanj/opnform-client
# (https://github.com/JhumanJ/OpnForm/pkgs/container/opnform)
APP_TAG=1.13.2
# nginx (https://hub.docker.com/_/nginx)
NGINX_TAG=1
# Maximum upload size passed to nginx (64m covers most form file uploads)
NGINX_MAX_BODY_SIZE=64m
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=16-alpine
# redis (https://hub.docker.com/_/redis)
REDIS_TAG=7.4-alpine

# --- Containers ---
CONTAINER_NAME_NGINX=${COMPOSE_PROJECT_NAME}-nginx
CONTAINER_NAME_API=${COMPOSE_PROJECT_NAME}-api
CONTAINER_NAME_UI=${COMPOSE_PROJECT_NAME}-ui
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_REDIS=${COMPOSE_PROJECT_NAME}-redis

# --- Database ---
DB_NAME=opnform
DB_USER=opnform
# Laravel backend reads DB_PASSWORD from env only (no _FILE support).
# Value must match contents of .secrets/db_pwd.txt.
DB_PWD_INLINE=__REPLACE_ME__

# --- App Key ---
# Laravel APP_KEY — encrypts sessions, cookies, password-reset tokens.
# Generate once with:
#   docker run --rm jhumanj/opnform-api:${APP_TAG} php artisan key:generate --show
# Keep the "base64:" prefix in the output. Rotating invalidates sessions.
APP_KEY=__REPLACE_ME__

# --- Registration ---
# "true"  = only the first-registered user becomes admin, further signups blocked
# "false" = anyone who reaches the URL can register
REGISTRATION_DISABLED=true

# --- Mail ---
# "log"  = write emails to the Laravel log (dev only)
# "smtp" = use the MAIL_HOST/PORT/USER/PASS settings below (prod)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=forms@example.com
MAIL_FROM_NAME=OpnForm

# Only used when MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# tls / ssl / null
MAIL_ENCRYPTION=tls

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
