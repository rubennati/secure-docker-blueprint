# =============================================
# PhotoPrism – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=photoprism

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=photos.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=2342
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# photoprism/photoprism (https://hub.docker.com/r/photoprism/photoprism)
APP_TAG=260305
# mariadb (https://hub.docker.com/_/mariadb)
DB_TAG=11.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- User Mapping ---
# Supported: 0, 33, 50-99, 500-600, 900-1200.
PUID=1000
PGID=1000

# --- Storage ---
# Source directory for original photos/videos. Can be a NAS mount.
ORIGINALS_PATH=./volumes/originals

# --- Database ---
DB_NAME=photoprism
DB_USER=photoprism
# PhotoPrism reads PHOTOPRISM_DATABASE_PASSWORD from a single env var
# (no _FILE support). Value must match contents of .secrets/db_pwd.txt.
DB_PWD_INLINE=__REPLACE_ME__

# --- Admin ---
ADMIN_USER=admin
# Generate once with: openssl rand -base64 24
# Only read on first startup; change in the UI afterwards and remove
# from .env so it is not kept on disk.
ADMIN_PASSWORD=__REPLACE_ME__

# --- Site metadata ---
SITE_TITLE=PhotoPrism
SITE_CAPTION=AI-Powered Photos App
DEFAULT_LOCALE=en
# "local" = place labels in the original language; "en"/"de" etc for translations
PLACES_LOCALE=local

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
