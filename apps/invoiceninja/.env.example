# =============================================
# Invoice Ninja – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

# --- Project ---
COMPOSE_PROJECT_NAME=invoiceninja

# --- Images ---
APP_TAG=5.13.16
MYSQL_TAG=8.4
REDIS_TAG=8.6.0-alpine
NGINX_TAG=1.27-alpine

# --- Containers ---
APP_CONTAINER=${COMPOSE_PROJECT_NAME}-app
NGINX_CONTAINER=${COMPOSE_PROJECT_NAME}-nginx
MYSQL_CONTAINER=${COMPOSE_PROJECT_NAME}-mysql
REDIS_CONTAINER=${COMPOSE_PROJECT_NAME}-redis

# --- Timezone ---
TZ=Europe/Vienna

# --- Traefik Routing ---
NETWORK_NAME=proxy-public
ROUTER_NAME=invoiceninja
SERVICE_NAME=invoiceninja
HOST_DOMAIN=invoice.example.com
CERT_RESOLVER=cloudflare-dns
TLS_OPTION=tls-basic
MIDDLEWARES=acc-tailscale@file,sec-3@file

# --- Invoice Ninja (App) ---
APP_ENV=production
APP_DEBUG=false
APP_URL=https://${HOST_DOMAIN}
REQUIRE_HTTPS=true
TRUSTED_PROXIES=*

# Generate with:
#   docker compose run --rm app php artisan key:generate --show
APP_KEY=__REPLACE_ME__

PHANTOMJS_PDF_GENERATION=false
PDF_GENERATOR=snappdf

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=debian_docker
IS_DOCKER=true
SCOUT_DRIVER=null

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ninja
DB_USERNAME=ninja
# DB_PASSWORD is injected via Docker Secret (secrets/db_pwd.txt)

# --- Initial User ---
# Set IN_USER_EMAIL for the first start. Password is injected via Docker Secret.
IN_USER_EMAIL=admin@example.com

# --- Mail ---
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=user@example.com
MAIL_FROM_NAME=Self Hosted User

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p secrets
#   openssl rand -base64 32 | tr -d '\n' > secrets/db_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > secrets/db_root_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > secrets/in_user_pwd.txt
