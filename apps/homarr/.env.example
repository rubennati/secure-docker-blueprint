# =============================================
# Homarr – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=homarr

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=homarr.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=7575
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# homarr-labs/homarr (https://github.com/homarr-labs/homarr/pkgs/container/homarr)
APP_TAG=v1.60.0

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- App Configuration ---
# 64-character hex encryption key used to encrypt stored integration
# credentials (API tokens for torrent clients, media servers, etc.).
#
# Generate with:
#   openssl rand -hex 32
#
# Upstream does not support _FILE suffix here — value stays in .env.
# Rotating this invalidates all stored integration credentials.
HOMARR_SECRET_ENCRYPTION_KEY=__REPLACE_ME__

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC
