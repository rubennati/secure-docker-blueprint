# =============================================
# Easy!Appointments – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=easyappointments

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=appointments.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# alextselegidis/easyappointments (https://hub.docker.com/r/alextselegidis/easyappointments)
APP_TAG=latest
# mariadb (https://hub.docker.com/_/mariadb)
DB_TAG=11.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=easyappointments
DB_USER=easyappointments
# Easy!Appointments reads DB_PASSWORD inline from env (no _FILE support).
# Value must match contents of .secrets/db_pwd.txt verbatim.
DB_PWD_INLINE=__REPLACE_ME__

# --- Timezone ---
TZ=UTC
