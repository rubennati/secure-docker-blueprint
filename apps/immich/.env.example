# =============================================
# Immich – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=immich

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=photos.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
# sec-2-spa: uses rl-spa (burst=200) instead of rl-soft (burst=50).
# Immich's service worker pre-caches ~100 JS chunks in parallel on first install.
# With rl-soft those requests hit the burst cap and return 429, leaving the app
# on a black screen. Average limit (100 req/s) is unchanged.
APP_TRAEFIK_SECURITY=sec-2-spa
APP_INTERNAL_PORT=2283
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# Immich server + machine-learning (https://github.com/immich-app/immich/releases)
APP_TAG=v2.7.5
# Immich-flavoured Postgres with pgvectors + vectorchord
# (https://github.com/immich-app/base-images/pkgs/container/postgres)
DB_TAG=14-vectorchord0.4.3-pgvectors0.2.0
# Valkey (Redis-compatible) — https://hub.docker.com/r/valkey/valkey
REDIS_TAG=8.1.6

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_ML=${COMPOSE_PROJECT_NAME}-ml
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_REDIS=${COMPOSE_PROJECT_NAME}-redis

# --- Storage ---
# Location where uploaded photos/videos are stored.
# Default: bind-mount under the app directory. Change to an external path
# (e.g. /mnt/nas/immich) for network storage — NFS/SMB are supported for
# the media upload volume only, NOT for the database volume.
UPLOAD_LOCATION=./volumes/library

# --- Database ---
DB_NAME=immich
DB_USER=immich
# Immich-server reads DB_PASSWORD from a single env var (no _FILE support).
# Value must match the content of ./.secrets/db_pwd.txt verbatim.
# Postgres container uses POSTGRES_PASSWORD_FILE from the same secret.
DB_PWD_INLINE=__REPLACE_ME__

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
