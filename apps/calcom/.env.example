# =============================================
# Cal.com – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=calcom

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=cal.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
APP_TRAEFIK_ACCESS=acc-public
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=3000
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# cal.com (https://hub.docker.com/r/calcom/cal.com)
APP_TAG=v6.2.0
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=17

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=calcom
DB_USER=calcom_user
# Cal.com's Prisma client reads one single DATABASE_URL and does not support
# URL-from-parts or *_FILE env vars. The password therefore has to be inline
# in the URL string the compose file assembles. Keep this value identical to
# the contents of ./.secrets/db_pwd.txt. See README "Known Issues".
DB_PWD_INLINE=__REPLACE_ME__

# --- Licensing ---
# Set to 'agree' to accept the Cal.com license
CALCOM_LICENSE_CONSENT=agree
CALCOM_LICENSE=

# --- Telemetry ---
CALCOM_TELEMETRY_DISABLED=1

# --- Email / SMTP ---
# Required for booking confirmations, reminders, admin notifications.
# Provider examples: smtp-relay.brevo.com, email-smtp.eu-west-1.amazonaws.com
CALCOM_EMAIL_FROM=calcom@example.com
CALCOM_EMAIL_FROM_NAME=Cal.com
CALCOM_SMTP_HOST=smtp.example.com
CALCOM_SMTP_PORT=587
CALCOM_SMTP_USER=

# --- Branding ---
CALCOM_APP_NAME=
CALCOM_COMPANY_NAME=
CALCOM_SUPPORT_EMAIL=

# --- Legal ---
CALCOM_TERMS_URL=
CALCOM_PRIVACY_URL=

# --- Organization ---
CALCOM_ORGS_ENABLED=false
CALCOM_SINGLE_ORG_SLUG=
CALCOM_ALLOWED_HOSTNAMES=

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and generate passwords/keys:
#   mkdir -p .secrets
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/nextauth_secret.txt
#   openssl rand -hex 16     | tr -d '\n' > .secrets/encryption_key.txt
#
# SMTP password (from provider):
#   printf '%s' 'YOUR-SMTP-PASSWORD' > .secrets/smtp_pwd.txt
#
# IMPORTANT: DB_PWD_INLINE above must match the contents of
# .secrets/db_pwd.txt verbatim — same string, no whitespace, no newline.
