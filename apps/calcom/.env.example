# =============================================
# Cal.com – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

# --- Images ---
APP_IMAGE=calcom/cal.com:v6.2.0
DB_IMAGE=postgres:17

# --- Container ---
CONTAINER_NAME_APP=calcom-app
CONTAINER_NAME_DB=calcom-db

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=calcom

# --- Database ---
DB_NAME=calcom
DB_USER=calcom_user
# NOTE: This is needed inline for DATABASE_URL construction.
# Must match the content of ./secrets/db_pwd.txt
DB_PWD_INLINE=__REPLACE_ME__

# --- Licensing ---
# Set to 'agree' to accept the Cal.com license
CALCOM_LICENSE_CONSENT=agree
CALCOM_LICENSE=

# --- Telemetry ---
CALCOM_TELEMETRY_DISABLED=1

# --- Email / SMTP ---
CALCOM_EMAIL_FROM=calcom@example.com
CALCOM_EMAIL_FROM_NAME=Cal.com
CALCOM_SMTP_HOST=smtp-relay.brevo.com
CALCOM_SMTP_PORT=587
CALCOM_SMTP_USER=

# --- Branding ---
CALCOM_APP_NAME=
CALCOM_COMPANY_NAME=
CALCOM_SUPPORT_EMAIL=

# --- Legal ---
CALCOM_TERMS_URL=
CALCOM_PRIVACY_URL=

# --- Organization ---
CALCOM_ORGS_ENABLED=false
CALCOM_SINGLE_ORG_SLUG=
CALCOM_ALLOWED_HOSTNAMES=

# --- Traefik Routing ---
APP_TRAEFIK_HOST=cal.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-basic
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=3000

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p secrets
#   openssl rand -base64 32 > secrets/db_pwd.txt
#   openssl rand -base64 32 > secrets/nextauth_secret.txt
#   dd if=/dev/urandom bs=1K count=1 2>/dev/null | md5sum | cut -d' ' -f1 > secrets/encryption_key.txt
#   (SMTP password manually)  > secrets/smtp_pwd.txt
#
# IMPORTANT: DB_PWD_INLINE above must match secrets/db_pwd.txt
