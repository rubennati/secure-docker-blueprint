# =============================================
# Seafile Pro – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=seafile-pro

# --- Compose Files ---
# Add/remove optional components here:
#   seasearch.yml           – Full-text search (recommended, lightweight)
#   seadoc.yml              – Collaborative document editing
#   notification-server.yml – Real-time file change notifications
#   md-server.yml           – File metadata management
#   thumbnail-server.yml    – Image/video thumbnail generation
#   clamav.yml              – Antivirus scanning (optional)
#   seafile-ai.yml          – AI features (optional, configure separately)
#
# NOTE: For Elasticsearch instead of SeaSearch, see UPSTREAM.md
#   clamav.yml              – Antivirus scanning (recommended for production)
COMPOSE_FILE=seafile-server.yml,seadoc.yml,notification-server.yml,md-server.yml,thumbnail-server.yml,seasearch.yml,clamav.yml
COMPOSE_PATH_SEPARATOR=,

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=files.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-basic
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# seafile-pro-mc (https://hub.docker.com/r/seafileltd/seafile-pro-mc)
APP_TAG=13.0-latest
# mariadb (https://hub.docker.com/_/mariadb)
DB_TAG=10.11
# redis (https://hub.docker.com/_/redis)
REDIS_TAG=7.4-alpine
# sdoc-server (https://hub.docker.com/r/seafileltd/sdoc-server)
SEADOC_TAG=2.0-latest
# notification-server (https://hub.docker.com/r/seafileltd/notification-server)
NOTIFICATION_TAG=13.0-latest
# seafile-md-server (https://hub.docker.com/r/seafileltd/seafile-md-server)
MD_TAG=13.0-latest
# thumbnail-server (https://hub.docker.com/r/seafileltd/thumbnail-server)
THUMBNAIL_TAG=13.0-latest
# seasearch (https://hub.docker.com/r/seafileltd/seasearch)
SEASEARCH_TAG=1.0-latest
# clamav (https://hub.docker.com/r/clamav/clamav)
CLAMAV_TAG=1.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_REDIS=${COMPOSE_PROJECT_NAME}-redis
CONTAINER_NAME_SEADOC=${COMPOSE_PROJECT_NAME}-seadoc
CONTAINER_NAME_NOTIFICATION=${COMPOSE_PROJECT_NAME}-notification
CONTAINER_NAME_MD_SERVER=${COMPOSE_PROJECT_NAME}-md-server
CONTAINER_NAME_THUMBNAIL=${COMPOSE_PROJECT_NAME}-thumbnail
CONTAINER_NAME_SEASEARCH=${COMPOSE_PROJECT_NAME}-seasearch
CONTAINER_NAME_CLAMAV=${COMPOSE_PROJECT_NAME}-clamav

# --- Network ---
NETWORK_INTERNAL=${COMPOSE_PROJECT_NAME}-internal

# --- Database ---
DB_USER=seafile

# --- Seafile ---
SEAFILE_ADMIN_EMAIL=admin@example.com

# Feature toggles
ENABLE_SEADOC=true
ENABLE_NOTIFICATION_SERVER=true
ENABLE_SEAFILE_AI=false
ENABLE_FACE_RECOGNITION=false

# Storage (disk or s3)
SEAF_SERVER_STORAGE_TYPE=disk
MD_STORAGE_TYPE=disk
SS_STORAGE_TYPE=disk

# --- SeaDoc ---
SEADOC_DB_NAME=seahub_db

# --- Notification ---
NOTIFICATION_LOG_LEVEL=info

# --- Metadata Server ---
MD_LOG_LEVEL=info
MD_MAX_CACHE_SIZE=1GB
MD_FILE_COUNT_LIMIT=100000

# --- Thumbnail Server ---
THUMBNAIL_SIZE_LIMIT=256

# --- SeaSearch ---
SS_MAX_OBJ_CACHE_SIZE=10GB
SS_LOG_LEVEL=info

# --- OnlyOffice Integration ---
# Hostname of your OnlyOffice Document Server (must match core/onlyoffice/.env)
ONLYOFFICE_HOST=office.example.com

# --- Timezone ---
TZ=Europe/Vienna

# --- Passwords & Keys ---
# TODO: Migrate to Docker Secrets when entrypoint wrapper supports my_init.
# For now, passwords are stored in .env (which is in .gitignore).
#
# Generate with:
#   openssl rand -base64 32 | tr -d '\n'   (for passwords)
#   openssl rand -base64 48 | tr -d '\n'   (for JWT — min 32 chars)
#   openssl rand -hex 32                    (for Redis — no +/= chars)
#
# OnlyOffice JWT secret must match core/onlyoffice — copy from there.
INIT_SEAFILE_MYSQL_ROOT_PASSWORD=__REPLACE_ME__
SEAFILE_MYSQL_DB_PASSWORD=__REPLACE_ME__
INIT_SEAFILE_ADMIN_PASSWORD=__REPLACE_ME__
JWT_PRIVATE_KEY=__REPLACE_ME__
REDIS_PASSWORD=__REPLACE_ME__
ONLYOFFICE_JWT_SECRET=__REPLACE_ME__

# IMPORTANT: After the very first start, you MUST restart the app container once:
#   docker compose restart app
# This injects OnlyOffice + Metadata settings into seahub_settings.py.
# Only needed once — survives all future restarts and updates.
