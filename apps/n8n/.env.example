# =============================================
# n8n – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=n8n

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=n8n.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-tailscale
# sec-1: n8n loads many JS/CSS assets simultaneously on first visit — any
# rate-limit middleware (sec-2+) triggers 429 errors on initial page load.
# sec-1 still sets basic security headers; no rate-limit is acceptable
# because the app is VPN-only (acc-tailscale).
APP_TRAEFIK_SECURITY=sec-1
APP_INTERNAL_PORT=5678
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# n8n (https://docs.n8n.io/hosting/installation/docker/)
APP_TAG=2.19.2

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Encryption key for stored credentials (OAuth tokens, API keys).
# CRITICAL: generate once, never rotate — changing it invalidates all stored credentials.
#   mkdir -p .secrets
#   openssl rand -hex 32 | tr -d '\n' > .secrets/n8n_encryption_key.txt
