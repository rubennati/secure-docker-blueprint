# =============================================
# n8n – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=n8n

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=n8n.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=5678
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# n8n (https://docs.n8n.io/hosting/installation/docker/)
APP_TAG=latest

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- Basic auth on the UI ---
# n8n's Community Edition has no user management by default. Basic auth
# is the minimum viable gate. Set BASIC_AUTH_ACTIVE=false only if you
# have put n8n behind another auth layer (Authentik forward-auth, etc.).
BASIC_AUTH_ACTIVE=true
BASIC_AUTH_USER=admin
# Generate with: openssl rand -base64 24
BASIC_AUTH_PASSWORD=__REPLACE_ME__

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
