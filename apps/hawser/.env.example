# =============================================
# Hawser – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# Remote Docker agent for Dockhand.
# Deploy on each Docker host that Dockhand should
# manage. Supports Edge mode (outbound WebSocket)
# and Standard mode (listen for connections).
#
# https://github.com/Finsys/hawser
# =============================================

# --- Images ---
APP_IMAGE=ghcr.io/finsys/hawser:v0.2.39
SOCKET_PROXY_IMAGE=tecnativa/docker-socket-proxy:v0.4.2

# --- Container ---
CONTAINER_NAME_APP=hawser-app
CONTAINER_NAME_SOCKET_PROXY=hawser-socket-proxy

# --- General ---
COMPOSE_PROJECT_NAME=hawser

# --- Edge Mode (default) ---
# Agent connects outbound to your Dockhand instance.
DOCKHAND_SERVER_URL=wss://dockhand.example.com/api/hawser/connect

# --- Standard Mode ---
# Uncomment these and remove DOCKHAND_SERVER_URL above
# to have the agent listen for incoming connections.
# HAWSER_PORT=2376
# HAWSER_BIND_ADDRESS=0.0.0.0

# --- Agent ---
AGENT_NAME=my-server
LOG_LEVEL=info

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p secrets
#   echo 'your-dockhand-agent-token' > secrets/hawser_token.txt
