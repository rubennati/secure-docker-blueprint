# =============================================
# Dockhand – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# Docker management UI with Git-based stack
# management, PostgreSQL backend, and socket proxy
# for restricted Docker API access.
# =============================================

# --- Images ---
APP_IMAGE=fnsys/dockhand:latest
DB_IMAGE=postgres:16-alpine
SOCKET_PROXY_IMAGE=tecnativa/docker-socket-proxy:0.3.0

# --- Container ---
CONTAINER_NAME_APP=dockhand-app
CONTAINER_NAME_DB=dockhand-db
CONTAINER_NAME_SOCKET_PROXY=dockhand-socket-proxy

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=dockhand

# --- Database ---
DB_USER=dockhand
DB_NAME=dockhand

# --- App Configuration ---
APP_PUID=1000
APP_PGID=1000

# --- Traefik Routing ---
APP_TRAEFIK_HOST=dockhand.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-modern
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-4

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p secrets
#   openssl rand -base64 32 > secrets/db_pwd.txt
#   openssl rand -base64 32 > secrets/encryption_key.txt
