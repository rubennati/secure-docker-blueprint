# =============================================
# Dockhand – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=dockhand

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=dockhand.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-modern
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
APP_TRAEFIK_SECURITY=sec-4
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# dockhand (https://hub.docker.com/r/fnsys/dockhand)
APP_TAG=v1.0.24
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=16-alpine
# tecnativa/docker-socket-proxy (https://hub.docker.com/r/tecnativa/docker-socket-proxy)
SOCKET_PROXY_TAG=v0.4.2

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_SOCKET_PROXY=${COMPOSE_PROJECT_NAME}-socket-proxy

# --- Database ---
DB_NAME=dockhand
DB_USER=dockhand

# --- App Configuration ---
APP_PUID=1000
APP_PGID=1000

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and generate passwords:
#   mkdir -p .secrets
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/encryption_key.txt
