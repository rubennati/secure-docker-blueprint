# =============================================
# Monica – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=monica

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=monica.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# Official monica image (https://hub.docker.com/_/monica)
APP_TAG=4.1.2-apache
# mariadb (https://hub.docker.com/_/mariadb)
DB_TAG=11.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=monica
DB_USER=monica
# Monica's Laravel config reads DB_PASSWORD from a single env var
# (no _FILE support). Value must match contents of .secrets/db_pwd.txt.
DB_PWD_INLINE=__REPLACE_ME__

# --- App Key ---
# Laravel APP_KEY — encrypts sessions, cookies, password-reset tokens.
# Generate once with:
#   docker run --rm monica:${APP_TAG} php artisan key:generate --show
# Keep the "base64:" prefix in the output. Rotating invalidates sessions.
APP_KEY=__REPLACE_ME__

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
