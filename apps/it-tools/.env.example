# =============================================
# IT-Tools – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=it-tools

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=tools.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
# Default: VPN-only — personal toolbox, not meant for public consumption.
# Set to acc-public if you want to share broadly (tool list is benign, static SPA).
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
# sec-3 is the sweet spot for a static SPA — strict headers without hard rate limit.
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# it-tools (https://github.com/CorentinTh/it-tools/pkgs/container/it-tools)
APP_TAG=2025.7.18-a0bc346

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC
