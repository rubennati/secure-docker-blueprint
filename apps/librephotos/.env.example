# =============================================
# LibrePhotos – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=librephotos

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=photos.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# reallibrephotos (https://hub.docker.com/u/reallibrephotos)
# Options: "latest" (weekly stable), "dev" (unstable), or a dated tag.
# "latest" is NOT reproducible — pin to a specific release when possible.
APP_TAG=latest
# pgautoupgrade handles Postgres major-version upgrades transparently
# (https://hub.docker.com/r/pgautoupgrade/pgautoupgrade)
DB_TAG=16-bookworm

# --- Containers ---
CONTAINER_NAME_PROXY=${COMPOSE_PROJECT_NAME}-proxy
CONTAINER_NAME_BACKEND=${COMPOSE_PROJECT_NAME}-backend
CONTAINER_NAME_FRONTEND=${COMPOSE_PROJECT_NAME}-frontend
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Storage ---
# Source directory for photos. LibrePhotos scans this read-only.
SCAN_DIRECTORY=./volumes/pictures

# --- Database ---
DB_NAME=librephotos
DB_USER=librephotos
# LibrePhotos reads DB_PASS from a single env var (no _FILE support).
# Value must match the content of ./.secrets/db_pwd.txt verbatim.
DB_PWD_INLINE=__REPLACE_ME__

# --- Admin bootstrap ---
# Created on first start if the database is empty.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
# Set once, then remove from .env after first successful login — the admin
# user can change their password in the UI.
ADMIN_PASSWORD=__REPLACE_ME__

# --- App behaviour ---
# Django SECRET_KEY — used for session cookies and CSRF tokens.
# Generate with: openssl rand -base64 48
SECRET_KEY=__REPLACE_ME__

# Mapbox token for the map view (optional — leave empty to disable).
MAPBOX_API_KEY=

# Gunicorn workers — 2-4 × CPU cores. Each worker uses ~500 MB RAM.
GUNICORN_WORKERS=2

# Glob patterns (pipe-separated) to skip during scan, e.g. ".*|*/Thumbs.db"
SKIP_PATTERNS=

# Allow users to upload photos via the web UI
ALLOW_UPLOAD=false

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
