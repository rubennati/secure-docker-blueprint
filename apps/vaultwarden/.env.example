# =============================================
# Vaultwarden – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
#
# SECURITY: This is a password manager.
# Use tls-modern (TLS 1.3), strong admin token,
# and disable signups after creating your accounts.
# =============================================

COMPOSE_PROJECT_NAME=vaultwarden

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=vault.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS 1.3 only — recommended for password managers
APP_TRAEFIK_TLS_OPTION=tls-modern
APP_TRAEFIK_ACCESS=acc-tailscale
# NOTE: sec-* middleware NOT used — Vaultwarden needs custom headers
# (SAMEORIGIN, same-origin, XSS-Protection:0). Custom middleware in compose.
# APP_TRAEFIK_SECURITY is not referenced in docker-compose.yml for this app.
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# vaultwarden (https://hub.docker.com/r/vaultwarden/server)
APP_TAG=1.35.7
# mariadb (https://hub.docker.com/_/mariadb)
DB_TAG=11.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=vaultwarden
DB_USER=vw_user

# --- Vaultwarden ---
# Set to true for initial account creation, then set to false
VW_SIGNUPS_ALLOWED=false
# Allow existing users/admins to invite new users (even when signups=false)
VW_INVITATIONS_ALLOWED=false
VW_LOG_LEVEL=warn

# --- Push Notifications (for mobile sync) ---
# Register free at https://bitwarden.com/host/ to get these keys
VW_PUSH_ENABLED=false
VW_PUSH_INSTALLATION_ID=
VW_PUSH_INSTALLATION_KEY=

# --- SMTP (required for 2FA recovery, invitations, etc.) ---
# SMTP provider (e.g. smtp.example.com, smtp-relay.brevo.com, smtp.mailgun.org)
VW_SMTP_HOST=
VW_SMTP_FROM=vault@example.com
VW_SMTP_PORT=587
VW_SMTP_SECURITY=starttls
VW_SMTP_USERNAME=
VW_SMTP_PASSWORD=

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Passwords & Keys ---
# Generate DB passwords (hex only — no special chars that break DATABASE_URL):
#   openssl rand -hex 32
#
# Or replace in-place:
#   sed -i "s|^DB_PASSWORD=.*|DB_PASSWORD=$(openssl rand -hex 32)|" .env
#   sed -i "s|^DB_ROOT_PASSWORD=.*|DB_ROOT_PASSWORD=$(openssl rand -hex 32)|" .env
DB_PASSWORD=__REPLACE_ME__
DB_ROOT_PASSWORD=__REPLACE_ME__

# Admin token — MUST be Argon2 hash, NOT plain text!
# Generate with:
#   docker run --rm -it vaultwarden/server:1.35.7 /vaultwarden hash
# Enter a strong password when prompted.
# Copy the $argon2id$... output below.
# IMPORTANT: In .env files, replace every $ with $$ (double dollar)
# Example: $$argon2id$$v=19$$m=65540,t=3,p=4$$...
VW_ADMIN_TOKEN=__REPLACE_ME__
