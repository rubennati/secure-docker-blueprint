# =============================================
# Vaultwarden – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

# --- Images ---
APP_IMAGE=vaultwarden/server:1.35.0
DB_IMAGE=mariadb:11.4

# --- Container ---
CONTAINER_NAME_APP=vaultwarden-app
CONTAINER_NAME_DB=vaultwarden-db

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=vaultwarden

# --- Database ---
DB_MYSQL_DATABASE=vaultwarden
DB_MYSQL_USER=vw_user

# --- App Configuration ---
VW_SIGNUPS_ALLOWED=false
VW_LOG_LEVEL=warn

# --- SMTP ---
VW_SMTP_HOST=smtp-relay.brevo.com
VW_SMTP_FROM=vaultwarden@example.com
VW_SMTP_PORT=587
VW_SMTP_SECURITY=starttls
VW_SMTP_USERNAME=

# --- Traefik Routing ---
APP_TRAEFIK_HOST=vault.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-modern
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=80

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p secrets
#   openssl rand -base64 32 > secrets/db_pwd.txt
#   openssl rand -base64 32 > secrets/db_root_pwd.txt
#   openssl rand -base64 48 > secrets/admin_token.txt
#   (SMTP password manually)  > secrets/smtp_pwd.txt
