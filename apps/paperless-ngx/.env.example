# =============================================
# Paperless-ngx – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=paperless

# --- Compose Files ---
# Add sso.yml to enable Authentik OpenID Connect login:
#   COMPOSE_FILE=docker-compose.yml,sso.yml
COMPOSE_FILE=docker-compose.yml
COMPOSE_PATH_SEPARATOR=,

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=paperless.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
# Default: VPN-only — Paperless holds personal documents, not a public service.
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=8000
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# paperless-ngx (https://github.com/paperless-ngx/paperless-ngx/pkgs/container/paperless-ngx)
APP_TAG=2.20.13
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=16.13
# redis (https://hub.docker.com/_/redis)
REDIS_TAG=7.4.7-alpine
# gotenberg (https://hub.docker.com/r/gotenberg/gotenberg)
GOTENBERG_TAG=8.21
# apache tika (https://hub.docker.com/r/apache/tika)
TIKA_TAG=3.1.0.0

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_REDIS=${COMPOSE_PROJECT_NAME}-redis
CONTAINER_NAME_GOTENBERG=${COMPOSE_PROJECT_NAME}-gotenberg
CONTAINER_NAME_TIKA=${COMPOSE_PROJECT_NAME}-tika

# --- Database ---
DB_NAME=paperless
DB_USER=paperless_user

# --- User Mapping ---
# Must match the UID/GID that owns ./volumes/ on the host.
USERMAP_UID=1000
USERMAP_GID=1000

# --- App Configuration ---
# OCR language(s): three-letter codes, comma-separated for multi-language.
# Common: eng, deu, fra, spa, ita. See Tesseract traineddata for full list.
PAPERLESS_OCR_LANGUAGE=deu
PAPERLESS_OCR_LANGUAGES=deu
# Limit OCR to the first N pages per document (0 = all)
PAPERLESS_OCR_PAGES=3
PAPERLESS_WORKERS=1
PAPERLESS_TASK_WORKERS=1
PAPERLESS_THREADS=2

# --- SSO (only active when sso.yml is in COMPOSE_FILE) ---
# Create an OAuth2/OIDC provider in Authentik, then set these.
# Redirect URI to configure in Authentik:
#   https://<APP_TRAEFIK_HOST>/accounts/oidc/<SSO_PROVIDER_ID>/login/callback/
# SSO_PROVIDER_ID=authentik
# SSO_PROVIDER_NAME=Single Sign-On
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
# SSO_SERVER_URL=https://auth.example.com/application/o/paperless/.well-known/openid-configuration

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and generate passwords/keys.
# Use `tr -d '\n'` — a trailing newline in a secret file causes
# Paperless-ngx to compare "password\n" vs "password" and reject logins.
#   mkdir -p .secrets
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_pwd.txt
#   openssl rand -base64 48 | tr -d '\n' > .secrets/secret_key.txt
