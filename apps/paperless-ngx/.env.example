# =============================================
# Paperless-ngx – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

# --- Compose Files ---
# Add optional components:
#   sso.yml  – Authentik OpenID Connect login
#   mcp.yml  – MCP server for AI assistants (Claude Code, etc.)
#   COMPOSE_FILE=docker-compose.yml,sso.yml,mcp.yml
COMPOSE_FILE=docker-compose.yml
COMPOSE_PATH_SEPARATOR=,

# --- Images ---
APP_IMAGE=ghcr.io/paperless-ngx/paperless-ngx:2.20.13
DB_IMAGE=postgres:16
REDIS_IMAGE=redis:7-alpine
GOTENBERG_IMAGE=gotenberg/gotenberg:8.21
TIKA_IMAGE=apache/tika:3.1.0.0

# --- Container ---
CONTAINER_NAME_APP=paperless-app
CONTAINER_NAME_DB=paperless-db
CONTAINER_NAME_REDIS=paperless-redis
CONTAINER_NAME_GOTENBERG=paperless-gotenberg
CONTAINER_NAME_TIKA=paperless-tika
CONTAINER_NAME_MCP=paperless-mcp

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=paperless

# --- Database ---
DB_NAME=paperless
DB_USER=paperless_user

# --- User Mapping ---
USERMAP_UID=1000
USERMAP_GID=1000

# --- App Configuration ---
PAPERLESS_OCR_LANGUAGE=deu
PAPERLESS_OCR_LANGUAGES=deu
PAPERLESS_OCR_PAGES=3
PAPERLESS_WORKERS=1
PAPERLESS_TASK_WORKERS=1
PAPERLESS_THREADS=2

# --- Traefik Routing ---
APP_TRAEFIK_HOST=paperless.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-basic
# Access: acc-public (unrestricted), acc-tailscale (VPN only)
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none), sec-1 (basic headers), sec-2 (standard), sec-3 (strict), sec-4 (strict + rate limit)
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=8000

# --- MCP Server (only with mcp.yml) ---
# Exposes Paperless documents to AI assistants via Model Context Protocol.
# Requires an API token from Paperless UI (Profile → Token).
MCP_TRAEFIK_HOST=paperless-mcp.example.com

# --- SSO (only with sso.yml) ---
# SSO_PROVIDER_ID=authentik
# SSO_PROVIDER_NAME=Single Sign-On
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
# SSO_SERVER_URL=https://auth.example.com/application/o/paperless/.well-known/openid-configuration

# --- Secrets ---
# Create the secrets directory and files:
# (Use -n with echo or printf to avoid trailing newlines — some apps
#  include the newline in the password, causing auth mismatches.)
#   mkdir -p secrets
#   openssl rand -base64 32 | tr -d '\n' > secrets/db_pwd.txt
#   openssl rand -base64 48 | tr -d '\n' > secrets/secret_key.txt
# For MCP server (generate token in Paperless UI first):
#   echo -n 'your-paperless-api-token' > secrets/mcp_api_token.txt
