# =============================================
# Paperless MCP Server – Environment
# =============================================
# MCP (Model Context Protocol) server for AI assistants.
# Provides Claude Code / Claude Desktop access to Paperless-ngx
# documents, tags, correspondents, and document types.
#
# Requires a running Paperless-ngx instance + API token.
# =============================================

# --- Container ---
CONTAINER_NAME_APP=paperless-mcp

# --- General ---
COMPOSE_PROJECT_NAME=paperless-mcp

# --- Paperless Connection ---
# URL of your Paperless-ngx instance (internal Docker network or external).
# If Paperless runs on the same Docker host and shares proxy-public network:
PAPERLESS_URL=http://paperless-app:8000

# --- Traefik Routing ---
APP_TRAEFIK_HOST=paperless-mcp.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-basic
# Access: acc-public (unrestricted), acc-tailscale (VPN only)
# IMPORTANT: This endpoint gives full access to your Paperless documents.
# Use acc-tailscale or set up authentication to protect it.
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none), sec-1 (basic headers), sec-2 (standard), sec-3 (strict), sec-4 (strict + rate limit)
APP_TRAEFIK_SECURITY=sec-3

# --- Secrets ---
# Generate an API token in the Paperless-ngx web UI:
#   → Profile (top right) → My Profile → Token → Copy
#   mkdir -p secrets
#   echo -n 'your-paperless-api-token' > secrets/mcp_api_token.txt
