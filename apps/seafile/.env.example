# =============================================
# Seafile CE – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

# --- Images ---
APP_IMAGE=seafileltd/seafile-mc:13.0.20
DB_IMAGE=mariadb:10.11
MEMCACHED_IMAGE=memcached:1.6-alpine
SEADOC_IMAGE=seafileltd/sdoc-server:1.0-latest

# --- Container ---
CONTAINER_NAME_APP=seafile-app
CONTAINER_NAME_DB=seafile-db
CONTAINER_NAME_MEMCACHED=seafile-memcached
CONTAINER_NAME_SEADOC=seafile-seadoc

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=seafile

# --- Compose Files ---
# Remove seadoc.yml to disable SeaDoc
COMPOSE_FILE=seafile-server.yml,seadoc.yml
COMPOSE_PATH_SEPARATOR=,

# --- Database ---
SEAFILE_DB_USER=seafile

# --- App Configuration ---
SEAFILE_ADMIN_EMAIL=admin@example.com
SEAFILE_ENABLE_SEADOC=true

# --- Traefik Routing ---
APP_TRAEFIK_HOST=files.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-basic
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=80

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p secrets
#   openssl rand -base64 32 > secrets/db_root_pwd.txt
#   openssl rand -base64 32 > secrets/seafile_db_pwd.txt
#   openssl rand -base64 32 > secrets/seafile_admin_pwd.txt
#   openssl rand -base64 48 > secrets/jwt_key.txt
