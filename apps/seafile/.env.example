# =============================================
# Seafile CE – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=seafile

# --- Compose Files ---
# Each YAML is an independent component. Add or remove to match the
# feature set you want to run. Order matters only for readability.
#   seafile-server.yml      – Core server (db, memcached, redis, seafile). REQUIRED.
#   seadoc.yml              – Collaborative document editing
#   notification-server.yml – Real-time file change notifications
#   md-server.yml           – File metadata + extended file properties
#   thumbnail-server.yml    – Image/video thumbnail generation
COMPOSE_FILE=seafile-server.yml,seadoc.yml,notification-server.yml,md-server.yml,thumbnail-server.yml
COMPOSE_PATH_SEPARATOR=,

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=files.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
APP_TRAEFIK_ACCESS=acc-public
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# Seafile Community Edition – multi-container distribution
APP_IMAGE=seafileltd/seafile-mc:13.0.20
DB_IMAGE=mariadb:10.11
MEMCACHED_IMAGE=memcached:1.6-alpine
REDIS_IMAGE=redis:7.4-alpine
# Sidecar images: Seafile does not publish stable digest-pinned tags for these.
# Look up the current tag for your Seafile CE version at:
#   https://hub.docker.com/u/seafileltd
SEADOC_IMAGE=__REPLACE_ME__
NOTIFICATION_SERVER_IMAGE=__REPLACE_ME__
MD_SERVER_IMAGE=__REPLACE_ME__
THUMBNAIL_SERVER_IMAGE=__REPLACE_ME__

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_MEMCACHED=${COMPOSE_PROJECT_NAME}-memcached
CONTAINER_NAME_REDIS=${COMPOSE_PROJECT_NAME}-redis
CONTAINER_NAME_SEADOC=${COMPOSE_PROJECT_NAME}-seadoc
CONTAINER_NAME_NOTIFICATION=${COMPOSE_PROJECT_NAME}-notification
CONTAINER_NAME_MD_SERVER=${COMPOSE_PROJECT_NAME}-md-server
CONTAINER_NAME_THUMBNAIL=${COMPOSE_PROJECT_NAME}-thumbnail

# --- Database ---
SEAFILE_DB_USER=seafile

# --- App Configuration ---
SEAFILE_ADMIN_EMAIL=admin@example.com
SEAFILE_ENABLE_SEADOC=true
SEAFILE_ENABLE_NOTIFICATION=true

# --- Notification Server ---
NOTIFICATION_LOG_LEVEL=info

# --- Metadata Server ---
MD_LOG_LEVEL=info
MD_MAX_CACHE_SIZE=1GB
MD_FILE_COUNT_LIMIT=100000

# --- Thumbnail Server ---
THUMBNAIL_SIZE_LIMIT=256

# --- OnlyOffice Integration ---
# Hostname of your OnlyOffice Document Server (must match core/onlyoffice/.env)
ONLYOFFICE_HOST=office.example.com

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TIMEZONE=UTC

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p .secrets
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_root_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/seafile_db_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/seafile_admin_pwd.txt
#   openssl rand -base64 48 | tr -d '\n' > .secrets/jwt_key.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/redis_pwd.txt
#
# OnlyOffice integration (copy from core/onlyoffice):
#   cp ../../core/onlyoffice/.secrets/jwt_secret.txt .secrets/onlyoffice_jwt_secret.txt
