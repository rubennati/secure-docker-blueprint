# =============================================
# Nextcloud – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=nextcloud

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=cloud.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-basic
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# nextcloud fpm-alpine (https://hub.docker.com/_/nextcloud)
APP_TAG=32-fpm-alpine
# mariadb LTS (https://hub.docker.com/_/mariadb)
DB_TAG=10.11
# redis (https://hub.docker.com/_/redis)
REDIS_TAG=7-alpine
# nginx (https://hub.docker.com/_/nginx)
NGINX_TAG=alpine-slim

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_REDIS=${COMPOSE_PROJECT_NAME}-redis
CONTAINER_NAME_NGINX=${COMPOSE_PROJECT_NAME}-nginx
CONTAINER_NAME_CRON=${COMPOSE_PROJECT_NAME}-cron

# --- Network ---
NETWORK_INTERNAL=${COMPOSE_PROJECT_NAME}-internal

# --- Database ---
DB_NAME=nextcloud
DB_USER=nextcloud

# --- Nextcloud ---
# Trusted proxy: Docker subnet of proxy-public network
# Find with: docker network inspect proxy-public --format '{{range .IPAM.Config}}{{.Subnet}}{{end}}'
NC_TRUSTED_PROXIES=172.19.0.0/16

# PHP tuning
PHP_MEMORY_LIMIT=1024M
PHP_UPLOAD_LIMIT=16G

# Redis password (used in compose command, not a secret file)
REDIS_PASSWORD=__REPLACE_ME__

# --- Timezone ---
TZ=Europe/Vienna

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p .secrets
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_root_pwd.txt
#   echo -n "admin" > .secrets/nc_admin_user.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/nc_admin_pwd.txt
#
# NOTE: After first successful login, change your admin password
# in Nextcloud and delete .secrets/nc_admin_pwd.txt
#
# FALLBACK: If fpm-alpine causes issues, switch to apache variant:
#   APP_TAG=32-apache
#   Remove the nginx service and mount nginx/nginx.conf
#   Move Traefik labels to the app service, port 80
