# =============================================
# Portainer CE – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# Docker management UI with a socket proxy
# for restricted Docker API access.
# No direct docker.sock mount on the app container.
# =============================================

# --- Images ---
APP_IMAGE=portainer/portainer-ce:2.39.1
SOCKET_PROXY_IMAGE=lscr.io/linuxserver/socket-proxy:3.2.15

# --- Container ---
CONTAINER_NAME_APP=portainer-app
CONTAINER_NAME_SOCKET_PROXY=portainer-socket-proxy

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=portainer

# --- Traefik Routing ---
APP_TRAEFIK_HOST=portainer.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-basic
# Access: acc-public (unrestricted), acc-tailscale (VPN only)
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none), sec-1 (basic headers), sec-2 (standard), sec-3 (strict), sec-4 (strict + rate limit)
APP_TRAEFIK_SECURITY=sec-4
