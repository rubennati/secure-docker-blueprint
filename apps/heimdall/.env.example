# =============================================
# Heimdall – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=heimdall

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=heimdall.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Personal dashboard — VPN-only default
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# linuxserver/heimdall (https://hub.docker.com/r/linuxserver/heimdall)
APP_TAG=2.6.3

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- User Mapping (LinuxServer.io PUID/PGID pattern) ---
# Must match the UID/GID that owns ./config/ on the host.
# Find with: id -u / id -g
PUID=1000
PGID=1000

# --- App Configuration ---
# Allow widgets (status checks, etc.) to probe internal networks?
# false = block internal probes (default, safer); true = allow
ALLOW_INTERNAL_REQUESTS=false

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC
