# =============================================
# Adminer – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=adminer

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=db.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
# STRONG RECOMMENDATION: acc-tailscale (or acc-private). Adminer exposes
# full database access — it must not be publicly reachable.
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
# sec-4 = strict headers + hard rate limit, appropriate for admin tools
APP_TRAEFIK_SECURITY=sec-4
APP_INTERNAL_PORT=8080
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# adminer (https://hub.docker.com/_/adminer)
APP_TAG=4.8.1-standalone

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- App Configuration ---
# Pre-select a server in the login form (optional convenience).
# Examples: wordpress-db, ghost-db, paperless-db. Leave empty for free entry.
ADMINER_DEFAULT_SERVER=

# UI theme. See /var/www/html/adminer/designs/ in the image for options.
# Popular: pepa-linha, nette, hever, mvt, lucas-sandery.
ADMINER_DESIGN=pepa-linha

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC
