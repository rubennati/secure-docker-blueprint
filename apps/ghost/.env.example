# =============================================
# Ghost – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=ghost

# --- Optional services ---
# ActivityPub enables Fediverse/Mastodon integration (followers on Mastodon etc.).
# Without ActivityPub:
COMPOSE_FILE=docker-compose.yml
# With ActivityPub (uncomment, comment out line above):
#COMPOSE_FILE=docker-compose.yml:docker-compose.activitypub.yml

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=blog.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
APP_TRAEFIK_ACCESS=acc-public
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=2368
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# ghost (https://hub.docker.com/_/ghost)
APP_TAG=6.27.0-alpine
# mysql (https://hub.docker.com/_/mysql)
DB_TAG=8.4
# ghost-activitypub (https://github.com/TryGhost/ActivityPub/releases)
ACTIVITYPUB_TAG=1.2.2
# ghost-activitypub-migrations (https://github.com/orgs/TryGhost/packages/container/package/activitypub-migrations)
ACTIVITYPUB_MIGRATIONS_TAG=1.2.2

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=ghost
DB_USER=ghost_user

# --- SMTP ---
# Required for member signup confirmation and newsletter sending.
# Ghost 6 sends an email verification code for every new-device login — SMTP
# must work before you can log in after clearing cookies.
#
# Brevo (smtp-relay.brevo.com):
#   Port 587 + STARTTLS → GHOST_MAIL_SECURE=false  (recommended)
#   Port 465 + SSL/TLS  → GHOST_MAIL_SECURE=true
#   GHOST_MAIL_USER = your Brevo account email address
#   GHOST_MAIL_PWD (secret) = SMTP key from Brevo → Transactional → SMTP & API
#
GHOST_MAIL_FROM=ghost@example.com
GHOST_MAIL_HOST=smtp-relay.brevo.com
GHOST_MAIL_SERVICE=
GHOST_MAIL_PORT=587
GHOST_MAIL_SECURE=false
GHOST_MAIL_USER=

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and generate passwords:
#   mkdir -p .secrets
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_root_pwd.txt
#
# SMTP password (from provider):
#   printf '%s' 'YOUR-SMTP-PASSWORD' > .secrets/mail_pwd.txt
