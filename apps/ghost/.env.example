# =============================================
# Ghost – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

# --- Images ---
APP_IMAGE=ghost:6.27.0-alpine
DB_IMAGE=mysql:8.4

# --- Container ---
CONTAINER_NAME_APP=ghost-app
CONTAINER_NAME_DB=ghost-db

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=ghost

# --- Database ---
DB_MYSQL_DATABASE=ghost
DB_MYSQL_USER=ghost_user

# --- SMTP ---
GHOST_MAIL_FROM=ghost@example.com
GHOST_MAIL_HOST=smtp-relay.brevo.com
GHOST_MAIL_SERVICE=brevo
GHOST_MAIL_PORT=465
GHOST_MAIL_USER=

# --- Traefik Routing ---
APP_TRAEFIK_HOST=blog.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-basic
# Access: acc-public (unrestricted), acc-tailscale (VPN only)
APP_TRAEFIK_ACCESS=acc-public
# Security: sec-0 (none), sec-1 (basic headers), sec-2 (standard), sec-3 (strict), sec-4 (strict + rate limit)
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=2368

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p secrets
#   openssl rand -base64 32 | tr -d '\n' > secrets/db_pwd.txt
#   openssl rand -base64 32 | tr -d '\n' > secrets/db_root_pwd.txt
#   (SMTP password manually)  > secrets/mail_pwd.txt
