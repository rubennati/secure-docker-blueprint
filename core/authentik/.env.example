# =============================================
# Authentik – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# SSO / Identity Provider. Used by other apps for
# centralized authentication via Forward-Auth or
# OAuth2/OIDC. First login at:
#   https://<HOST>/if/flow/initial-setup/
# =============================================

# --- Images ---
APP_IMAGE=ghcr.io/goauthentik/server:2024.12.3
DB_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7.4-alpine

# --- Container ---
CONTAINER_NAME_SERVER=authentik-server
CONTAINER_NAME_WORKER=authentik-worker
CONTAINER_NAME_DB=authentik-db
CONTAINER_NAME_REDIS=authentik-redis

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=authentik

# --- Database ---
DB_USER=authentik
DB_NAME=authentik

# --- SMTP ---
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=10
SMTP_FROM=noreply@example.com

# --- Traefik Routing ---
APP_TRAEFIK_HOST=auth.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-basic
# Access: acc-public (unrestricted), acc-tailscale (VPN only)
APP_TRAEFIK_ACCESS=acc-public
# Security: sec-0 (none), sec-1 (basic headers), sec-2 (standard), sec-3 (strict), sec-4 (strict + rate limit)
APP_TRAEFIK_SECURITY=sec-2

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p secrets
#   openssl rand -base64 32 | tr -d '\n' > secrets/db_pwd.txt
#   openssl rand -base64 60 | tr -d '\n' > secrets/authentik_secret_key.txt
#   echo 'your-smtp-password' > secrets/smtp_password.txt
