# =============================================
# Authentik – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# SSO / Identity Provider. Used by other apps for
# centralised authentication via Forward-Auth or
# OAuth2 / OIDC.
#
# First login at:
#   https://<APP_TRAEFIK_HOST>/if/flow/initial-setup/
# =============================================

COMPOSE_PROJECT_NAME=authentik

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=auth.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
APP_TRAEFIK_ACCESS=acc-public
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
# sec-3 = strict headers + soft rate limit, appropriate for an auth provider.
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=9000
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# goauthentik server (https://github.com/goauthentik/authentik/pkgs/container/server)
APP_TAG=2026.2.2
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=16-alpine
# redis (https://hub.docker.com/_/redis)
REDIS_TAG=7.4-alpine
# alpine — used only by the short-lived init-perms container that chowns
# ./volumes/{data,certs,custom-templates} to UID 1000 before server/worker start
INIT_IMAGE=alpine:3.19

# --- Containers ---
CONTAINER_NAME_INIT=${COMPOSE_PROJECT_NAME}-init-perms
CONTAINER_NAME_SERVER=${COMPOSE_PROJECT_NAME}-server
CONTAINER_NAME_WORKER=${COMPOSE_PROJECT_NAME}-worker
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_REDIS=${COMPOSE_PROJECT_NAME}-redis

# --- Database ---
DB_NAME=authentik
DB_USER=authentik

# --- SMTP ---
# Required for password-reset, invitations, event notifications.
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=10
SMTP_FROM=noreply@example.com

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and generate passwords/keys:
#   mkdir -p .secrets
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_pwd.txt
#   openssl rand -base64 60 | tr -d '\n' > .secrets/authentik_secret_key.txt
#
# SMTP password (from provider):
#   printf '%s' 'YOUR-SMTP-PASSWORD' > .secrets/smtp_password.txt
