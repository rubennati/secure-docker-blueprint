# =============================================
# acme-certs – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# Certificate issuing tool using acme.sh with
# Cloudflare DNS-01 challenge. For devices that
# don't go through Traefik (NAS, routers, etc.).
#
# Supports: Let's Encrypt, ZeroSSL, Buypass.
# =============================================

# --- Images ---
APP_IMAGE=neilpang/acme.sh:3.1.2

# --- Container ---
CONTAINER_NAME_APP=acme-certs

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=acme-certs

# --- ACME Configuration ---
ACME_EMAIL=admin@example.com
ACME_SERVER=letsencrypt
CERT_KEYLENGTH=ec-256

# --- Default Certificate ---
# Used by wizard.sh as defaults. Override per invocation.
CERT_DOMAIN=example.com
CERT_SAN=*.example.com

# --- Secrets ---
# Create the secrets directory and file:
#   mkdir -p secrets
#   echo 'your-cloudflare-api-token' > secrets/cf_token.txt
#
# Token needs: Zone > DNS > Edit permission on the target zone.
# Use a scoped API Token, NOT the Global API Key.
