# =============================================
# OnlyOffice Document Server – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# This is a central service used by other apps
# (Seafile, Nextcloud, etc.) for office document
# editing in the browser.
#
# After setup, configure each app to connect to:
#   https://<APP_TRAEFIK_HOST>/web-apps/apps/api/documents/api.js
# with the JWT secret from ./.secrets/jwt_secret.txt
# =============================================

# --- Images ---
APP_IMAGE=onlyoffice/documentserver:8.3

# --- Container ---
CONTAINER_NAME_APP=onlyoffice-app

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=onlyoffice

# --- Integration ---
# Domains allowed to embed OnlyOffice in an iframe (CSP frame-ancestors).
# Space-separated, each with https:// prefix.
# Example single app:   https://files.example.com
# Example multi-app:    https://files.example.com https://cloud.example.com
ONLYOFFICE_ALLOWED_ORIGINS=https://files.example.com https://cloud.example.com

# --- Traefik Routing ---
APP_TRAEFIK_HOST=office.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-basic
# Access: acc-public (unrestricted), acc-tailscale (VPN only)
APP_TRAEFIK_ACCESS=acc-public
# NOTE: APP_TRAEFIK_SECURITY is NOT used for OnlyOffice.
# OnlyOffice needs to be embedded in iframes, but all sec-* levels set
# X-Frame-Options: DENY which blocks this. Instead, the docker-compose.yml
# defines a custom security middleware (onlyoffice-headers) with the same
# protections but iframe embedding allowed via frame-ancestors CSP.
APP_INTERNAL_PORT=80

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p secrets
#   openssl rand -base64 30 | tr -d '\n' > .secrets/jwt_secret.txt
