# =============================================
# OnlyOffice Document Server – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# Central service for in-browser office document
# editing, used by apps like Seafile, Nextcloud,
# or anything WOPI-compatible.
#
# After setup, each consuming app connects to:
#   https://<APP_TRAEFIK_HOST>/web-apps/apps/api/documents/api.js
# and authenticates with the JWT secret in
#   ./.secrets/jwt_secret.txt
# =============================================

COMPOSE_PROJECT_NAME=onlyoffice

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=office.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
APP_TRAEFIK_ACCESS=acc-public
# NOTE: APP_TRAEFIK_SECURITY is intentionally NOT used for OnlyOffice.
# Every sec-* chain sets X-Frame-Options: DENY, which blocks iframe
# embedding in Seafile / Nextcloud. The docker-compose.yml defines a
# dedicated middleware chain with the same protections but
# iframe embedding permitted via Content-Security-Policy frame-ancestors.
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# onlyoffice/documentserver (https://hub.docker.com/r/onlyoffice/documentserver)
APP_TAG=8.3

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- Integration ---
# Domains allowed to embed OnlyOffice in an iframe (CSP frame-ancestors).
# Space-separated, each with https:// prefix.
#   Single app:   https://files.example.com
#   Multi-app:    https://files.example.com https://cloud.example.com
ONLYOFFICE_ALLOWED_ORIGINS=https://files.example.com https://cloud.example.com

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and generate the JWT secret:
#   mkdir -p .secrets
#   openssl rand -base64 30 | tr -d '\n' > .secrets/jwt_secret.txt
#
# Each consuming app (Seafile, Nextcloud, …) needs the same secret:
#   cp .secrets/jwt_secret.txt ../../apps/<app>/.secrets/onlyoffice_jwt_secret.txt
