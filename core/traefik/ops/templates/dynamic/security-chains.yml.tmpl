http:
  middlewares:

    # ==========================================================
    # SECURITY POLICY CHAINS (presets)
    # ==========================================================
    # Pick a level per router. Higher = stricter.
    # "e" variants   = iframe-friendly (SAMEORIGIN instead of DENY).
    # "spa" variants = high-burst rate limit for code-split SPAs (VPN-only).
    #
    # Building blocks are defined in security-blocks.yml.
    #
    # Level      Content                                  Use case
    # ---------  ---------------------------------------  ----------------------------
    # sec-0      nothing                                  Debug, naked proxy
    # sec-1      basic headers + compress                 Internal tools (no rl)
    # sec-1e     ↑ iframe-friendly variant                Internal, must be embedded
    # sec-2      sec-1 + rl-soft                          Standard (most apps)
    # sec-2e     ↑ iframe-friendly variant                Standard, must be embedded
    # sec-2-spa  sec-1 + rl-spa                           VPN-only SPA, basic headers
    # sec-3      sec-2 + strict headers + permissions     Public-facing, hardened
    # sec-3e     ↑ iframe-friendly variant                Hardened, must be embedded
    # sec-3-spa  sec-3 with rl-spa instead of rl-soft     VPN-only SPA, hardened
    # sec-4      sec-3 with rl-hard                       Sensitive (login, admin)
    # sec-5      sec-4 + CSP enforce                      Maximum (CSP-tested only)
    #
    # Examples:
    #   WordPress        → sec-2      (CMS with inline scripts)
    #   Nextcloud        → sec-3      (public-facing, hardened)
    #   Vaultwarden      → sec-3e     (strict + SAMEORIGIN for browser extension)
    #   OnlyOffice       → sec-2e     (embeddable in iframes)
    #   Traefik Dashboard→ sec-4      (admin UI, hard rate limit)
    #   Whoami           → sec-5      (static page, perfect for CSP enforce)
    #   NocoDB / n8n     → sec-3-spa  (VPN-only SPA, many parallel chunk requests)
    #
    # Recommendation: Start with sec-2 for new apps.
    # Upgrade to sec-3 when the app handles strict headers.
    # Use sec-*e only when the app must be embedded in iframes.
    # Use sec-*-spa only for VPN-gated apps (network-level access control).
    # ==========================================================

    # Debug — no hardening at all
    sec-0:
      chain:
        middlewares: []

    # Internal tools — basic security headers + compression, no rate limit
    sec-1:
      chain:
        middlewares:
          - hdr-basic
          - compress

    # Internal tools, iframe-friendly
    sec-1e:
      chain:
        middlewares:
          - hdr-basic-embed
          - compress

    # Standard — recommended default for most apps
    sec-2:
      chain:
        middlewares:
          - hdr-basic
          - rl-soft
          - compress

    # Standard, iframe-friendly
    sec-2e:
      chain:
        middlewares:
          - hdr-basic-embed
          - rl-soft
          - compress

    # Standard, SPA burst — VPN-only code-split SPAs (basic headers)
    sec-2-spa:
      chain:
        middlewares:
          - hdr-basic
          - rl-spa
          - compress

    # Hardened — public-facing apps, strict headers
    sec-3:
      chain:
        middlewares:
          - hdr-strict
          - rl-soft
          - compress
          - permissions-policy

    # Hardened, iframe-friendly
    sec-3e:
      chain:
        middlewares:
          - hdr-strict-embed
          - rl-soft
          - compress
          - permissions-policy

    # Hardened, SPA burst — VPN-only code-split SPAs (strict headers)
    sec-3-spa:
      chain:
        middlewares:
          - hdr-strict
          - rl-spa
          - compress
          - permissions-policy

    # Sensitive — hard rate limit, login pages, admin panels
    sec-4:
      chain:
        middlewares:
          - hdr-strict
          - rl-hard
          - compress
          - permissions-policy

    # Maximum — only for apps tested with enforcing CSP
    sec-5:
      chain:
        middlewares:
          - hdr-strict
          - rl-hard
          - compress
          - permissions-policy
          - csp-enforce
