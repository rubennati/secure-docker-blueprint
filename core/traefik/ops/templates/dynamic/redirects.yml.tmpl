#       middlewares:
#         - redirect-to-new@file
#       service: noop@internal
#       tls:
#         certResolver: ${ACME_RESOLVER_DNS}
#         options: tls-basic
#
#   middlewares:
#     redirect-to-new:
#       redirectRegex:
#         regex: "^https?://old\\.example\\.com/(.*)"
#         replacement: "https://new.example.com/$1"
#         permanent: true
