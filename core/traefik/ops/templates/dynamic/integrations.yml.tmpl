# ==========================================================
# INTEGRATIONS — CrowdSec + Authentik
# ==========================================================
# External services that plug into Traefik as middleware.
# Each is independent — enable/disable per router.
# Add "middleware-name@file" to a router's middleware list.
#
# This file is empty by default (fully commented out).
#
# To enable:
#   1. Uncomment the `http:` + `middlewares:` header below
#   2. Uncomment ONE OR BOTH of the middleware blocks
#      (CrowdSec / Authentik)
#   3. Add "<name>@file" to the router middleware list of each
#      router that should use it
#
# Traefik hot-reloads — no restart needed.
# ==========================================================

http:
  middlewares:

    # ------------------------------------------------------
    # CrowdSec Bouncer Plugin
    # ------------------------------------------------------
    # Prerequisites:
    #   1. core/crowdsec running + on proxy-public network
    #   2. Plugin loaded in traefik.yml (experimental.plugins)
    #   3. Bouncer key: docker exec crowdsec cscli bouncers add traefik-bouncer
    #   4. CROWDSEC_BOUNCER_KEY=<key> in .env
    #
    # Mode: stream (polls LAPI every 60s, caches decisions).
    #
    # AppSec/WAF is disabled here by default. The AppSec process does
    # not auto-start with CrowdSec — it needs its own config in
    # core/crowdsec/config/appsec.yaml and the port 7422 to be reachable
    # from Traefik. With crowdsecAppsecEnabled=true + unreachable AppSec,
    # crowdsecAppsecUnreachableBlock=true makes the bouncer fail-closed
    # on EVERY request (HTTP 403), which is almost always not what you
    # want for first setup. Enable AppSec only after its server side is
    # verified reachable (`curl crowdsec:7422` from the Traefik container).
    #
    # Geo-blocking: install crowdsecurity/geoloc-enrich collection
    #   + a scenario like crowdsecurity/cdn-whitelist
    # ------------------------------------------------------
#     sec-crowdsec:
#       plugin:
#         bouncer:
#           enabled: true
#           crowdsecMode: stream
#           updateIntervalSeconds: 60
#           crowdsecLapiScheme: http
#           crowdsecLapiHost: crowdsec:8080
#           crowdsecLapiKey: "${CROWDSEC_BOUNCER_KEY}"
#           crowdsecAppsecEnabled: false
#           crowdsecAppsecHost: crowdsec:7422
#           crowdsecAppsecFailureBlock: false
#           crowdsecAppsecUnreachableBlock: false

    # ------------------------------------------------------
    # Authentik (SSO / Forward Auth)
    # ------------------------------------------------------
    # Requires: core/authentik running + outpost configured.
    # See core/authentik/README.md — "Integrating other apps via Forward-Auth"
    #
    # address points to the Authentik outpost endpoint. Traefik calls this URL
    # for every request before forwarding it to the target app.
    # The address can point to any reachable host — it does NOT have to be on
    # the same Docker host as Traefik. Examples:
    #   Same host (default): http://authentik-server:9000/...
    #   Other machine in LAN: http://192.168.1.50:9000/...
    #   Central auth server:  https://auth.example.com/...
    # ------------------------------------------------------
#     sec-authentik:
#       forwardAuth:
#         address: "http://authentik-server:9000/outpost.goauthentik.io/auth/traefik"
#         trustForwardHeader: true
#         authResponseHeaders:
#           - X-authentik-username
#           - X-authentik-groups
#           - X-authentik-email
#           - X-authentik-name
#           - X-authentik-uid
#           - X-authentik-jwt
#           - X-authentik-meta-jwks
#           - X-authentik-meta-outpost
#           - X-authentik-meta-provider
#           - X-authentik-meta-app
#           - X-authentik-meta-version
