global:
  checkNewVersion: false
  sendAnonymousUsage: false

log:
  level: ${TRAEFIK_LOG_LEVEL}
  format: ${TRAEFIK_LOG_FORMAT}
  filePath: "${TRAEFIK_LOG_FILE}"

accessLog:
  filePath: "${TRAEFIK_ACCESSLOG_FILE}"
  format: ${TRAEFIK_ACCESSLOG_FORMAT}
  bufferingSize: ${TRAEFIK_ACCESSLOG_BUFFER}
  filters:
    statusCodes:
      - "400-599"
    retryAttempts: true

api:
  dashboard: true
  insecure: false

ping:
  entryPoint: ping

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https

  websecure:
    address: ":443"
    http3:
      advertisedPort: 443
    http:
      tls:
        options: ${TLS_DEFAULT_OPTION}

  ping:
    address: "127.0.0.1:8082"

providers:
  docker:
    endpoint: "${DOCKER_SOCKET_PROXY_ENDPOINT}"
    exposedByDefault: false
    network: "${PUBLIC_NETWORK}"

  file:
    directory: "/etc/traefik/dynamic"
    watch: true

providersThrottleDuration: 30s

certificatesResolvers:
  ${ACME_RESOLVER_DNS}:
    acme:
      email: "${ACME_EMAIL}"
      storage: "${ACME_STORAGE}"
      dnsChallenge:
        provider: cloudflare
        resolvers:
          - "${ACME_DNS_RESOLVER_1}"
          - "${ACME_DNS_RESOLVER_2}"

  ${ACME_RESOLVER_HTTP}:
    acme:
      email: "${ACME_EMAIL}"
      storage: "${ACME_STORAGE}"
      httpChallenge:
        entryPoint: web
