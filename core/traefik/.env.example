# =============================================
# Traefik Reverse Proxy – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

# ------------------------------------------------------------
# Core
# ------------------------------------------------------------
TIMEZONE=Europe/Vienna

# Images
TRAEFIK_IMAGE=traefik:v3.6
SOCKET_PROXY_IMAGE=tecnativa/docker-socket-proxy:v0.4.2

# Container names
TRAEFIK_CONTAINER_NAME=traefik-core
SOCKET_PROXY_CONTAINER_NAME=traefik-socket-proxy

# Networks
PUBLIC_NETWORK=proxy-public
SOCKET_PROXY_NETWORK=socket_proxy_net

# ------------------------------------------------------------
# Ports (host)
# ------------------------------------------------------------
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443

# ------------------------------------------------------------
# Docker Socket Proxy endpoint used by Traefik
# Must match the docker-compose service name + port.
# ------------------------------------------------------------
DOCKER_SOCKET_PROXY_ENDPOINT=tcp://docker-socket-proxy:2375

# ------------------------------------------------------------
# Tailscale
# ------------------------------------------------------------
TAILSCALE_CIDR=100.64.0.0/10

# ------------------------------------------------------------
# ACME / Let's Encrypt
# ------------------------------------------------------------
ACME_EMAIL=letsencrypt@example.com
ACME_STORAGE=/etc/traefik/acme/acme.json

# Resolver names (must match config/traefik.yml)
ACME_RESOLVER_DNS=cloudflare-dns
ACME_RESOLVER_HTTP=httpResolver

# Cloudflare DNS-01
# Use an API Token with: Zone:Read + DNS:Edit
CF_DNS_API_TOKEN=__REPLACE_ME__

# DNS resolvers used for ACME DNS checks
ACME_DNS_RESOLVER_1=1.1.1.1:53
ACME_DNS_RESOLVER_2=8.8.8.8:53

# Wildcard certificate domain (optional – leave empty to skip)
# ACME_WILDCARD_DOMAIN=example.com

# ------------------------------------------------------------
# System Routes
# ------------------------------------------------------------
TRAEFIK_DASHBOARD_HOST=traefik.example.com

# TLS options
TLS_DEFAULT_OPTION=tls-basic
TRAEFIK_DASHBOARD_TLS_OPTION=tls-modern
TRAEFIK_DASHBOARD_CERT_RESOLVER=cloudflare-dns

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_LOG_FORMAT=json
TRAEFIK_LOG_FILE=/var/log/traefik/traefik.log

TRAEFIK_ACCESSLOG_FORMAT=json
TRAEFIK_ACCESSLOG_FILE=/var/log/traefik/access.log
TRAEFIK_ACCESSLOG_BUFFER=100

# ------------------------------------------------------------
# Docker Socket Proxy (HAProxy template variables)
# ------------------------------------------------------------
DSP_LOG_LEVEL=info
DSP_SOCKET_PATH=/var/run/docker.sock
DSP_BIND_CONFIG=0.0.0.0:2375
DSP_POST=0
