# =============================================
# Portainer CE – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=portainer

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=portainer.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-modern
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
APP_TRAEFIK_SECURITY=sec-4
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# portainer-ce (https://hub.docker.com/r/portainer/portainer-ce)
APP_TAG=2.39.1
# linuxserver/socket-proxy (https://hub.docker.com/r/linuxserver/socket-proxy)
SOCKET_PROXY_TAG=3.2.15

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_SOCKET_PROXY=${COMPOSE_PROJECT_NAME}-socket-proxy

# --- Edge Agent support (optional) ---
# Only set if you also deploy Portainer Edge Agents on other hosts
# (see core/portainer-agent/). Agents reach this central Portainer
# via TCP 8000. Set to the Tailscale IP of this host — NOT 0.0.0.0,
# and NOT a LAN IP that's reachable from the public internet.
# Then uncomment the matching `ports:` line in docker-compose.yml.
# Example: PORTAINER_EDGE_BIND=100.95.21.13
# PORTAINER_EDGE_BIND=

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# No external secrets required. Portainer prompts for an admin password
# on first-time access through the web UI. Credentials are stored
# bcrypt-hashed in ./volumes/data/portainer.db.
