# =============================================
# Whoami – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# Tiny HTTP echo service for testing Traefik
# routing, TLS certificates, and middleware chains.
# Disable or remove after verification.
# =============================================

COMPOSE_PROJECT_NAME=whoami

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=whoami.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-basic
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly.
# sec-5 = maximum (CSP enforce). Whoami is static — perfect for strictest policy.
APP_TRAEFIK_SECURITY=sec-5
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# traefik/whoami (https://hub.docker.com/r/traefik/whoami)
APP_TAG=v1.11.0

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}

# --- Secrets ---
# None required. Whoami has no state and no authentication.
