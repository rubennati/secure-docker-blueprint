# =============================================
# Hawser – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# Remote Docker agent for Dockhand.
# Deploy on each Docker host that Dockhand should manage.
# https://github.com/Finsys/hawser
# =============================================

COMPOSE_PROJECT_NAME=hawser

# --- Images ---
# hawser (https://github.com/Finsys/hawser/pkgs/container/hawser)
APP_TAG=0.2.39

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- Edge Mode ---
# Agent connects outbound to your Dockhand instance via WebSocket.
# No port opening needed, works behind NAT/Firewall/Tailscale.
DOCKHAND_SERVER_URL=wss://dockhand.example.com/api/hawser/connect

# --- Agent ---
AGENT_NAME=my-server
LOG_LEVEL=info

# --- Token ---
# Get from Dockhand: Add Host → Hawser agent (edge) → Generate connection token
# Create the secrets directory and file:
#   mkdir -p .secrets
#   echo -n 'your-dockhand-agent-token' > .secrets/hawser_token.txt
