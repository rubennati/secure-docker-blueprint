# =============================================
# dnsmasq – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# Lightweight DNS forwarder / cache for internal
# and Tailscale-based environments. Provides
# wildcard zones for test/dev/prod routing.
#
# NOTE: This service uses network_mode: "host"
# and does NOT go through Traefik.
# =============================================

COMPOSE_PROJECT_NAME=dnsmasq

# --- Images ---
# dnsmasq (https://hub.docker.com/r/4km3/dnsmasq)
APP_TAG=2.90-r3

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}

# --- DNS Configuration ---
DNS_UPSTREAM_1=1.1.1.1
DNS_UPSTREAM_2=9.9.9.9
DNS_CACHE_SIZE=10000
DNS_NEG_TTL=60
DNS_LOCAL_DOMAIN=lab

# --- Listen Interfaces ---
# Comma-separated is NOT supported by dnsmasq.
# Each interface becomes its own line in the config.
DNS_INTERFACE_1=lo
DNS_INTERFACE_2=tailscale0
# DNS_INTERFACE_3=enp1s0

# --- Wildcard Zones ---
# Route all *.subdomain.example.com to a single IP.
# Uncomment and adjust in the rendered config as needed.
DNS_WILDCARD_1_DOMAIN=test.lab.example.com
DNS_WILDCARD_1_IP=100.100.100.10
DNS_WILDCARD_2_DOMAIN=dev.lab.example.com
DNS_WILDCARD_2_IP=100.100.100.20
# DNS_WILDCARD_3_DOMAIN=prod.lab.example.com
# DNS_WILDCARD_3_IP=100.100.100.30

# --- Logging ---
# true = log all queries (verbose), false = silent
DNS_LOG_QUERIES=true
