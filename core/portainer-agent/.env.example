# =============================================
# Portainer Agent – Environment
# =============================================

COMPOSE_PROJECT_NAME=portainer-agent

# --- Images ---
# portainer/agent — keep in sync with your central portainer/portainer-ce version
APP_TAG=2.39.1

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}

# --- Agent secret ---
# Shared secret between this agent and the central Portainer server.
# Generate once: openssl rand -hex 32
# Same value must be entered in Portainer UI when adding the environment.
AGENT_SECRET=__REPLACE_ME__
