# =============================================
# Portainer Agent – Environment (Edge Mode default)
# =============================================

COMPOSE_PROJECT_NAME=portainer-agent

# --- Images ---
# portainer/agent — keep major version in sync with central portainer/portainer-ce
APP_TAG=2.39.1

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}

# --- Edge Mode ---
# In the central Portainer UI:
#   Environments → Add environment → Docker Standalone → Edge Agent
#   → copy EDGE_ID and EDGE_KEY shown on the wizard
# Paste them below. The agent then opens an outbound WebSocket to
# the central Portainer — no inbound port needed.
EDGE_ID=__REPLACE_ME__
EDGE_KEY=__REPLACE_ME__

# --- Classic Mode (only when NOT using Edge — see docker-compose.yml) ---
# Generate: openssl rand -hex 32
# Same value must be entered in Portainer UI as the agent shared secret.
# AGENT_SECRET=__REPLACE_ME__
