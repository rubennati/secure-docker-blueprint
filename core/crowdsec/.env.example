# =============================================
# CrowdSec – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

# --- Images ---
APP_IMAGE=crowdsecurity/crowdsec:v1.7.7

# --- Container ---
CONTAINER_NAME_APP=crowdsec

# --- General ---
TIMEZONE=Europe/Vienna
COMPOSE_PROJECT_NAME=crowdsec

# --- CrowdSec Configuration ---
# GID that owns the Traefik log files (run: stat -c '%g' /var/log/traefik/)
CROWDSEC_LOG_GID=0

# Collections to install on first start (space-separated)
CROWDSEC_COLLECTIONS=crowdsecurity/traefik crowdsecurity/http-cve crowdsecurity/appsec-generic-rules crowdsecurity/appsec-virtual-patching

# LAPI port exposed on localhost (for firewall bouncer on host)
CROWDSEC_LAPI_PORT=8080

# --- Traefik Logs ---
# Path to Traefik access logs on the host
# Must match the Traefik log output path
TRAEFIK_LOG_PATH=/var/log/traefik
