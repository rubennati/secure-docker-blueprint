# =============================================
# CrowdSec – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=crowdsec

# --- Images ---
# crowdsec (https://hub.docker.com/r/crowdsecurity/crowdsec)
APP_TAG=v1.7.7

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}

# --- CrowdSec Configuration ---
# GID that owns the Traefik log files
# Find with: stat -c '%g' /path/to/docker-ops-blueprint/core/traefik/volumes/logs/access.log
CROWDSEC_LOG_GID=0

# Collections to install on first start (space-separated)
# Browse: https://hub.crowdsec.net/
CROWDSEC_COLLECTIONS=crowdsecurity/traefik crowdsecurity/http-cve crowdsecurity/appsec-generic-rules crowdsecurity/appsec-virtual-patching

# LAPI port exposed on localhost (for firewall bouncer on host)
CROWDSEC_LAPI_PORT=8080

# --- Traefik Logs ---
# Default: relative path (traefik and crowdsec in same core/ directory)
# Override with absolute path if traefik is elsewhere
# Example absolute: /path/to/docker-ops-blueprint/core/traefik/volumes/logs
TRAEFIK_LOG_PATH=../traefik/volumes/logs

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC
