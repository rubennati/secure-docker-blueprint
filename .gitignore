# =============================================
# Docker Ops Blueprint – .gitignore
# =============================================

# -----------------------------------------
# Inbox (local working area, never committed)
# -----------------------------------------
inbox/

# -----------------------------------------
# Environment files (contain secrets)
# -----------------------------------------
.env
**/.env
!**/.env.example

# -----------------------------------------
# Docker runtime data
# -----------------------------------------
**/data/
**/logs/
**/acme.json

# -----------------------------------------
# OS and editor files
# -----------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
