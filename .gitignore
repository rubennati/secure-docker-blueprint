# =============================================
# Docker Ops Blueprint – .gitignore
# =============================================

# -----------------------------------------
# Inbox (local working area, never committed)
# -----------------------------------------
inbox/

# -----------------------------------------
# Environment files (contain secrets)
# -----------------------------------------
.env
**/.env
!**/.env.example

# -----------------------------------------
# Docker runtime data
# -----------------------------------------
**/volumes/
**/logs/
**/acme.json

# -----------------------------------------
# Secrets (passwords, tokens, keys)
# -----------------------------------------
**/secrets/

# -----------------------------------------
# OS and editor files
# -----------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# -----------------------------------------
# Tool state (Claude Code, AI assistants)
# -----------------------------------------
.claude/
