# =============================================
# App Name – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=myapp

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=myapp.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict + A+), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
APP_TRAEFIK_ACCESS=acc-public
# Security: sec-0 (none) to sec-5 (maximum). "e" suffix = iframe-friendly
APP_TRAEFIK_SECURITY=sec-2
APP_INTERNAL_PORT=80
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# your-image (https://hub.docker.com/r/org/image)
APP_TAG=1.0.0
# mariadb (https://hub.docker.com/_/mariadb)
DB_TAG=11.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=myapp
DB_USER=myapp_user

# --- App Configuration ---
# Add app-specific variables here

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and generate passwords:
#   mkdir -p .secrets
#
# For URL-embedded passwords (DATABASE_URL, REDIS_URL): use hex
#   openssl rand -hex 32 | tr -d '\n' > .secrets/db_pwd.txt
#   openssl rand -hex 32 | tr -d '\n' > .secrets/db_root_pwd.txt
#
# For other secrets (tokens, keys): base64 is fine
#   openssl rand -base64 32 | tr -d '\n' > .secrets/app_secret.txt
