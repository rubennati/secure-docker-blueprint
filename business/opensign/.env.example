# =============================================
# OpenSign – Environment
# =============================================
COMPOSE_PROJECT_NAME=opensign

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=sign.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-3
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# NOTE: OpenSign does not publish semver tags to Docker Hub.
# Only "main", "staging", and "docker_beta" exist. Use "main" for production.
APP_TAG=main
DB_TAG=6

# --- Containers ---
CONTAINER_NAME_API=${COMPOSE_PROJECT_NAME}-api
CONTAINER_NAME_UI=${COMPOSE_PROJECT_NAME}-ui
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- App ---
# Display name shown in verification emails
APP_NAME=OpenSign
# Master key — full Parse Server bypass. Keep strong and secret.
# Generate: openssl rand -hex 32
MASTER_KEY=__REPLACE_ME__

# --- Database ---
DB_NAME=OpenSignDB
DB_ROOT_USER=opensign
# OpenSign's Parse Server builds the Mongo DSN inline — no _FILE support.
# Value must match contents of .secrets/db_root_pwd.txt.
# IMPORTANT: use alphanumeric only — @:/?# break DSN parsing.
DB_ROOT_PWD_INLINE=__REPLACE_ME__

# --- Document signing certificate ---
# Base64-encoded PFX/p12 certificate for PDF signing.
# Generate a self-signed cert (see README.md) or upload a qualified CA cert for eIDAS.
# Generate: openssl rand -hex 24  (as passphrase), then follow README steps.
PFX_BASE64=__REPLACE_ME__
PASS_PHRASE=__REPLACE_ME__

# --- Mail (choose one) ---
# Option A: Mailgun API
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_SENDER=

# Option B: SMTP (set SMTP_ENABLE=true to use instead of Mailgun)
SMTP_ENABLE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER_EMAIL=mailer@example.com
SMTP_PASS=

# --- Timezone ---
TZ=UTC
