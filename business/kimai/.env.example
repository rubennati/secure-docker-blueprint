# =============================================
# Kimai – Environment
# =============================================
COMPOSE_PROJECT_NAME=kimai

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=time.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=8001
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# kimai/kimai2 (https://hub.docker.com/r/kimai/kimai2)
APP_TAG=apache-2.56.0
DB_TAG=11.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=kimai
DB_USER=kimai
# Kimai assembles DATABASE_URL inline. Password must be URL-safe
# (no @, :, /, ?, #). openssl rand -hex is safe.
DB_PWD_INLINE=__REPLACE_ME__

# --- App secret ---
# Generate with: openssl rand -hex 32
APP_SECRET=__REPLACE_ME__

# --- Admin (only read on first boot to seed the first user) ---
ADMIN_EMAIL=admin@example.com
# Generate: openssl rand -base64 16
ADMIN_PASSWORD=__REPLACE_ME__

# --- Timezone ---
TZ=UTC
