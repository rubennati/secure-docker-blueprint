# =============================================
# Vikunja – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=vikunja

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=tasks.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-basic
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# vikunja/vikunja (https://hub.docker.com/r/vikunja/vikunja)
APP_TAG=2.3.0
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=17-alpine

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=vikunja
DB_USER=vikunja

# --- App Configuration ---
# Authentik OIDC — set to true once Authentik is configured (see README).
# Leave false on first run to use local login only.
VIKUNJA_AUTH_OPENID_ENABLED=false

# Required when VIKUNJA_AUTH_OPENID_ENABLED=true:
# 1. Create an OAuth2/OIDC provider in Authentik for Vikunja
#    Redirect URI (Strict): https://<APP_TRAEFIK_HOST>/auth/openid/authentik
# 2. Fill in the values below
AUTHENTIK_DOMAIN=auth.example.com
# Application slug as defined in Authentik (used in the issuer URL)
AUTHENTIK_APP_SLUG=vikunja
# Client ID from the Authentik provider
OIDC_CLIENT_ID=__REPLACE_ME__

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p .secrets
#   openssl rand -base64 48 | tr -d '\n' > .secrets/jwt_key.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_pwd.txt
#   OIDC secret — must exist even when OIDC is disabled (Docker mounts it regardless):
#   echo -n "placeholder" > .secrets/oidc_secret.txt
#   Replace with the real Client Secret from Authentik when enabling OIDC.
