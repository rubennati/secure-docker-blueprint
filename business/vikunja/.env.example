# =============================================
# Vikunja – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=vikunja

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=tasks.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-basic
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# vikunja/vikunja (https://hub.docker.com/r/vikunja/vikunja)
APP_TAG=2.3.0
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=17-alpine

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=vikunja
DB_USER=vikunja

# --- App Configuration ---

# Authentik OIDC — set to true once Authentik is configured (see README).
# Leave false on first run to use local login only.
VIKUNJA_AUTH_OPENID_ENABLED=false

# Required when VIKUNJA_AUTH_OPENID_ENABLED=true:
# 1. Create an OAuth2/OIDC provider in Authentik for Vikunja
#    Redirect URI (Strict): https://<APP_TRAEFIK_HOST>/auth/openid/authentik
# 2. Fill in the values below
AUTHENTIK_DOMAIN=auth.example.com
# Application slug as defined in Authentik (used in the issuer URL)
AUTHENTIK_APP_SLUG=vikunja
# Client ID from the Authentik provider
OIDC_CLIENT_ID=__REPLACE_ME__

# Access control
# Set VIKUNJA_ENABLEREGISTRATION=true only during initial setup (first user = admin).
# Disable again once your admin account is created via OIDC.
VIKUNJA_ENABLEREGISTRATION=false
# Set to false to disable local username/password login and enforce SSO-only.
# Only disable after confirming Authentik login works!
VIKUNJA_LOCAL_AUTH_ENABLED=false

# --- Branding (optional) ---
# Logo must be reachable via HTTPS. Leave empty for default Vikunja logo.
VIKUNJA_CUSTOMLOGOURL=
VIKUNJA_CUSTOMLOGOURLDARK=
# Set false to prevent seasonal icon changes (halloween etc.) when using a custom logo
VIKUNJA_ALLOWICONCHANGES=true

# --- Legal (optional — shown in frontend footer when set) ---
VIKUNJA_IMPRINTURL=
VIKUNJA_PRIVACYURL=

# --- Message of the Day (optional — shown in frontend) ---
VIKUNJA_MOTD=

# --- Default settings for new users ---
# Language: de, en, fr, etc. (ISO 639-1). Leave empty for browser language.
VIKUNJA_DEFAULT_LANGUAGE=de
# Week start: 0=Sunday, 1=Monday
VIKUNJA_DEFAULT_WEEK_START=1
# Avatar: initials, gravatar, marble
VIKUNJA_DEFAULT_AVATAR=initials

# --- Features ---
VIKUNJA_ENABLELINKSHARING=true
VIKUNJA_BACKGROUNDS_ENABLED=true
# CalDAV endpoint (lets users sync tasks to calendar apps)
VIKUNJA_ENABLECALDAV=true
# TOTP / 2FA for local login (irrelevant when SSO-only, safe to disable)
VIKUNJA_ENABLETOTP=true
# Allow users to request account deletion
VIKUNJA_ENABLEUSERDELETION=false
# Make teams publicly discoverable when sharing projects
VIKUNJA_ENABLEPUBLICTEAMS=false
# Webhooks for external integrations (n8n, Zapier, etc.)
VIKUNJA_WEBHOOKS_ENABLED=true

# --- Mailer / SMTP ---
# Set VIKUNJA_MAILER_ENABLED=true and fill in the values below.
# SMTP password goes in .secrets/smtp_pwd.txt — never in .env.
VIKUNJA_MAILER_ENABLED=false
VIKUNJA_MAILER_HOST=smtp.example.com
VIKUNJA_MAILER_PORT=587
VIKUNJA_MAILER_USERNAME=vikunja@example.com
VIKUNJA_MAILER_FROMEMAIL=vikunja@example.com
# AUTHTYPE: plain (default), login, cram-md5
VIKUNJA_MAILER_AUTHTYPE=plain
# FORCESSL: true = SMTPS port 465 | false = STARTTLS port 587
VIKUNJA_MAILER_FORCESSL=false

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p .secrets
#   openssl rand -base64 48 | tr -d '\n' > .secrets/jwt_key.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_pwd.txt
#   OIDC secret — must exist even when OIDC is disabled (Docker mounts it regardless):
#   echo -n "placeholder" > .secrets/oidc_secret.txt
#   Replace with the real Client Secret from Authentik when enabling OIDC.
#   SMTP password — must exist even when mailer is disabled:
#   echo -n "placeholder" > .secrets/smtp_pwd.txt
#   Replace with the real SMTP password when enabling the mailer.
