###############################################################################
# PROJECT
###############################################################################
COMPOSE_PROJECT_NAME=vikunja

###############################################################################
# CONTAINERS
###############################################################################
APP_CONTAINER=${COMPOSE_PROJECT_NAME}-app
DB_CONTAINER=${COMPOSE_PROJECT_NAME}-db

###############################################################################
# NETWORKS
###############################################################################
NETWORK_NAME=proxy-public

###############################################################################
# ROUTING (TRAEFIK)
###############################################################################
ROUTER_NAME=vikunja
SERVICE_NAME=vikunja
HOST_DOMAIN=tasks.example.com

###############################################################################
# TLS / ACME
###############################################################################
CERT_RESOLVER=cloudflare-dns
TLS_OPTION=tls-basic

###############################################################################
# MIDDLEWARES (File Provider)
###############################################################################
MIDDLEWARES=acc-tailscale@file,sec-3@file

###############################################################################
# TIMEZONE
###############################################################################
TZ=UTC

###############################################################################
# IMAGES
###############################################################################
# vikunja/vikunja (https://hub.docker.com/r/vikunja/vikunja)
APP_TAG=2.3.0
# postgres (https://hub.docker.com/_/postgres)
# Upstream docs use postgres:18 — using 17-alpine to match blueprint standard.
DB_TAG=17-alpine

###############################################################################
# DATABASE
###############################################################################
DB_USER=vikunja
DB_NAME=vikunja

###############################################################################
# AUTHENTIK OIDC
# Set to false to skip OIDC on first run (local login only).
# Set to true once Authentik is configured (see README for full setup steps).
###############################################################################
VIKUNJA_AUTH_OPENID_ENABLED=false

# Required when VIKUNJA_AUTH_OPENID_ENABLED=true:
# 1. In Authentik: create an OAuth2/OIDC provider for Vikunja
#    - Redirect URI (Strict): https://<HOST_DOMAIN>/auth/openid/authentik
#    - Scopes: openid profile email
#    - Note the Client ID and Client Secret
# 2. Create an Application pointing to the provider
# 3. Fill in the values below
AUTHENTIK_DOMAIN=auth.example.com
# Application slug as defined in Authentik (used in the issuer/authurl)
AUTHENTIK_APP_SLUG=vikunja
# Client ID from the Authentik provider
OIDC_CLIENT_ID=__REPLACE_ME__

###############################################################################
# SECRETS — generate and store in .secrets/ (no trailing newlines)
# mkdir -p .secrets
# echo -n "$(openssl rand -base64 48 | tr -d '\n')" > .secrets/VIKUNJA_JWT_SECRET
# echo -n "$(openssl rand -base64 32 | tr -d '\n')" > .secrets/VIKUNJA_DB_PWD
# OIDC secret — required even when OIDC is disabled (Docker mounts it regardless).
# Use a placeholder if not yet configured:
# echo -n "placeholder" > .secrets/VIKUNJA_OIDC_SECRET
# Replace with the real Client Secret from Authentik when enabling OIDC.
###############################################################################
