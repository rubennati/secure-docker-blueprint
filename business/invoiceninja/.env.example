###############################################################################
# PROJECT
###############################################################################
COMPOSE_PROJECT_NAME=invoiceninja

###############################################################################
# CONTAINERS
###############################################################################
APP_CONTAINER=${COMPOSE_PROJECT_NAME}-app
NGINX_CONTAINER=${COMPOSE_PROJECT_NAME}-nginx
MYSQL_CONTAINER=${COMPOSE_PROJECT_NAME}-mysql
REDIS_CONTAINER=${COMPOSE_PROJECT_NAME}-redis

###############################################################################
# NETWORKS
###############################################################################
NETWORK_NAME=proxy-public

###############################################################################
# ROUTING (TRAEFIK)
###############################################################################
ROUTER_NAME=invoiceninja
SERVICE_NAME=invoiceninja
HOST_DOMAIN=invoice.example.com

###############################################################################
# TLS / ACME
###############################################################################
CERT_RESOLVER=cloudflare-dns
TLS_OPTION=tls-basic

###############################################################################
# MIDDLEWARES (File Provider)
###############################################################################
MIDDLEWARES=acc-tailscale@file,sec-3@file

###############################################################################
# TIMEZONE
###############################################################################
TZ=Europe/Vienna

###############################################################################
# IMAGES
###############################################################################
# invoiceninja-debian (https://hub.docker.com/r/invoiceninja/invoiceninja-debian)
APP_TAG=5.13.16
# mysql (https://hub.docker.com/_/mysql)
MYSQL_TAG=8.4
# redis (https://hub.docker.com/_/redis)
REDIS_TAG=8.6.0-alpine
# nginx (https://hub.docker.com/_/nginx)
NGINX_TAG=1.29.5-alpine

###############################################################################
# INVOICE NINJA (APP)
###############################################################################
APP_ENV=production
APP_DEBUG=false
APP_URL=https://${HOST_DOMAIN}
REQUIRE_HTTPS=true
TRUSTED_PROXIES=*

# Generate with: docker compose run --rm app php artisan key:generate --show
APP_KEY=__REPLACE_ME__

PHANTOMJS_PDF_GENERATION=false
PDF_GENERATOR=snappdf

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=debian_docker
IS_DOCKER=true
SCOUT_DRIVER=null

###############################################################################
# DB connection
###############################################################################
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ninja
DB_USERNAME=ninja

###############################################################################
# MySQL Container env
###############################################################################
MYSQL_DATABASE=${DB_DATABASE}
MYSQL_USER=${DB_USERNAME}

###############################################################################
# Create initial user
###############################################################################
IN_USER_EMAIL=admin@example.com

###############################################################################
# Mail options
###############################################################################
MAIL_MAILER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=user@example.com
MAIL_FROM_NAME=Self Hosted User

###############################################################################
# Passwords & Keys
###############################################################################
# TODO: Migrate to Docker Secrets when supported.
# Generate with: openssl rand -base64 32 | tr -d '\n'
DB_PASSWORD=__REPLACE_ME__
DB_ROOT_PASSWORD=__REPLACE_ME__
MYSQL_PASSWORD=${DB_PASSWORD}
MYSQL_ROOT_PASSWORD=${DB_ROOT_PASSWORD}
IN_PASSWORD=__REPLACE_ME__
