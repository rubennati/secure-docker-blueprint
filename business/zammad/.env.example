# =============================================
# Zammad – Environment
# =============================================
COMPOSE_PROJECT_NAME=zammad

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=support.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
APP_TRAEFIK_ACCESS=acc-public
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=8080
TRAEFIK_NETWORK=proxy-public

# --- Images ---
APP_TAG=7.0.1
DB_TAG=16-alpine
REDIS_TAG=7.4.7-alpine
MEMCACHED_TAG=1.6.41
# Zammad 7.x requires Elasticsearch 8.x (Bitnami image).
# Verify the latest 8.x tag at https://hub.docker.com/r/bitnami/elasticsearch/tags
# before first boot — Bitnami rotates older tags.
ES_TAG=8.17.4

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-nginx
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db
CONTAINER_NAME_REDIS=${COMPOSE_PROJECT_NAME}-redis
CONTAINER_NAME_MEMCACHED=${COMPOSE_PROJECT_NAME}-memcached
CONTAINER_NAME_ES=${COMPOSE_PROJECT_NAME}-elasticsearch

# --- Database ---
DB_NAME=zammad_production
DB_USER=zammad
# Zammad Rails reads POSTGRESQL_PASS from env only (no _FILE support).
DB_PWD_INLINE=__REPLACE_ME__

# --- Timezone ---
TZ=UTC
