# =============================================
# Listmonk – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=listmonk

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=newsletter.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
# IMPORTANT: subscribers need to reach /subscription/*, /link/*, /campaign/*.
# Start with acc-public so tracking pixels + unsubscribe links work.
# For the admin UI behind VPN-only, see README (two-router setup).
APP_TRAEFIK_ACCESS=acc-public
# sec-2e: SAMEORIGIN instead of DENY — required for the campaign/template
# preview panel, which renders in an iframe inside the admin UI.
APP_TRAEFIK_SECURITY=sec-2e
APP_INTERNAL_PORT=9000
TRAEFIK_NETWORK=proxy-public

# --- Images ---
APP_TAG=v6.1.0
DB_TAG=16-alpine

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_NAME=listmonk
DB_USER=listmonk
# Listmonk reads LISTMONK_db__password from env only (no _FILE support).
DB_PWD_INLINE=__REPLACE_ME__

# --- Admin ---
# In v6+, the super admin is created via the web UI on first visit.
# No ADMIN_USER / ADMIN_PASSWORD env vars needed.

# --- Timezone ---
TZ=UTC
