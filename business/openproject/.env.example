###############################################################################
# PROJECT
###############################################################################
COMPOSE_PROJECT_NAME=openproject

###############################################################################
# CONTAINERS
###############################################################################
WEB_CONTAINER=${COMPOSE_PROJECT_NAME}-web
WORKER_CONTAINER=${COMPOSE_PROJECT_NAME}-worker
CRON_CONTAINER=${COMPOSE_PROJECT_NAME}-cron
SEEDER_CONTAINER=${COMPOSE_PROJECT_NAME}-seeder
CACHE_CONTAINER=${COMPOSE_PROJECT_NAME}-cache
DB_CONTAINER=${COMPOSE_PROJECT_NAME}-db

###############################################################################
# NETWORKS
###############################################################################
NETWORK_NAME=proxy-public

###############################################################################
# ROUTING (TRAEFIK)
###############################################################################
ROUTER_NAME=openproject
SERVICE_NAME=openproject
HOST_DOMAIN=project.example.com

###############################################################################
# TLS / ACME
###############################################################################
CERT_RESOLVER=cloudflare-dns
TLS_OPTION=tls-basic

###############################################################################
# MIDDLEWARES (File Provider)
###############################################################################
MIDDLEWARES=acc-tailscale@file,sec-3@file

###############################################################################
# TIMEZONE
###############################################################################
TZ=UTC

###############################################################################
# IMAGES
###############################################################################
# openproject/openproject slim (https://hub.docker.com/r/openproject/openproject)
# Use non-floating X.Y.Z-slim tags in production.
APP_TAG=17.3.1-slim
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=17-alpine
# memcached (https://hub.docker.com/_/memcached)
MEMCACHED_TAG=1.6-alpine

###############################################################################
# DATABASE
###############################################################################
DB_USER=openproject
DB_NAME=openproject

###############################################################################
# OPENPROJECT
###############################################################################
# Language for initial seed data (types, status names, demo data).
# Set before first run — changing this after seeding has no effect.
OPENPROJECT_DEFAULT_LANGUAGE=en

###############################################################################
# SECRETS — generate and store in .secrets/
# echo -n "$(openssl rand -base64 64 | tr -d '\n')" > .secrets/OP_SECRET_KEY_BASE
# echo -n "$(openssl rand -base64 32 | tr -d '\n')" > .secrets/OP_DB_PWD
###############################################################################
