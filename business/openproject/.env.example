# =============================================
# OpenProject CE – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=openproject

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=project.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-basic
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# openproject/openproject (https://hub.docker.com/r/openproject/openproject)
# Slim variant: no embedded webserver — Traefik routes directly to port 8080.
# Pin to X.Y.Z-slim — migrations run on every version update.
APP_TAG=17.3.1-slim
# postgres (https://hub.docker.com/_/postgres)
DB_TAG=17-alpine
# memcached (https://hub.docker.com/_/memcached)
MEMCACHED_TAG=1.6-alpine

# --- Containers ---
CONTAINER_NAME_WEB=${COMPOSE_PROJECT_NAME}-web
CONTAINER_NAME_WORKER=${COMPOSE_PROJECT_NAME}-worker
CONTAINER_NAME_CRON=${COMPOSE_PROJECT_NAME}-cron
CONTAINER_NAME_SEEDER=${COMPOSE_PROJECT_NAME}-seeder
CONTAINER_NAME_CACHE=${COMPOSE_PROJECT_NAME}-cache
CONTAINER_NAME_DB=${COMPOSE_PROJECT_NAME}-db

# --- Database ---
DB_USER=openproject
DB_NAME=openproject

# --- App Configuration ---
# Language for initial seed data (types, status names, demo data).
# Set before first run — changing this after seeding has no effect.
OPENPROJECT_DEFAULT_LANGUAGE=en

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC

# --- Secrets ---
# Create the secrets directory and files:
#   mkdir -p .secrets
#   openssl rand -base64 64 | tr -d '\n' > .secrets/secret_key_base.txt
#   openssl rand -base64 32 | tr -d '\n' > .secrets/db_pwd.txt
