# =============================================
# Uptime Kuma – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=uptime-kuma

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=uptime.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Default: VPN-only because the admin UI shows all probe results,
# target hostnames, response bodies, and notification webhook URLs.
# Public status pages (/status/<slug>) inherit the same chain —
# switch to acc-public if you want external users to see statuses.
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=3001
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# louislam/uptime-kuma (https://hub.docker.com/r/louislam/uptime-kuma)
# Tag "1" tracks stable v1.x. v2 is beta — do NOT pin to "2" in prod.
APP_TAG=1

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/London, America/New_York
TZ=UTC
