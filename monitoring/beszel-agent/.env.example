# =============================================
# Beszel Agent – Environment
# =============================================
# Standalone agent for remote hosts monitored by a central Beszel hub.
# Deploy on each additional host; the hub runs on monitoring/beszel/.
#
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=beszel-agent

# --- Images ---
# henrygd/beszel-agent (https://github.com/henrygd/beszel/pkgs/container/beszel-agent)
# TODO: Beszel is pre-1.0 — pin to a specific release tag for stability.
# Keep in sync with the hub's APP_TAG.
APP_TAG=0

# --- Containers ---
CONTAINER_NAME_AGENT=${COMPOSE_PROJECT_NAME}

# --- App Configuration ---
# SSH port the agent listens on. The hub connects to this port.
# Change only if 45876 conflicts with another agent on the same host.
AGENT_PORT=45876
# Hub's SSH public key — from the hub UI ("+ Add System", top right).
# Paste the FULL key including the "ssh-ed25519" type prefix:
#   AGENT_KEY=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA...
# Not just the base64 portion — the type prefix is required.
# One hub key works for all agents.
AGENT_KEY=
# Optional: comma-separated mount points the agent should report on
# beyond the root FS. Example: /mnt/nas,/var/lib/docker
EXTRA_FILESYSTEMS=
# WebSocket reverse-connection (optional). Only needed when the hub cannot
# SSH to this host (e.g. agent behind strict NAT). Leave empty on Tailnet.
# HUB_URL=https://beszel.example.com

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC
