# =============================================
# Gatus – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=gatus

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=gatus.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Gatus shows all endpoint URLs, response conditions, alert destinations.
# VPN-only by default — switch to acc-public only if you want the
# status page externally reachable and trust your config.yaml redaction.
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=8080
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# twinproduction/gatus (https://hub.docker.com/r/twinproduction/gatus)
APP_TAG=v5.34.0

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- Logging ---
# TRACE, DEBUG, INFO, WARN, ERROR, FATAL
LOG_LEVEL=INFO

# --- Timezone ---
TZ=UTC
