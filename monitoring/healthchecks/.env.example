# =============================================
# Healthchecks – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================
#
# Self-hosted cron / scheduled-task monitoring.
# Tasks ping a URL on schedule; Healthchecks alerts
# when expected pings are missed.
# =============================================

COMPOSE_PROJECT_NAME=healthchecks

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=health.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
# TLS profile: tls-basic (TLS 1.2), tls-aplus (TLS 1.2 strict), tls-modern (TLS 1.3 only)
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Access: acc-public, acc-local, acc-tailscale, acc-private, acc-deny
# IMPORTANT: the monitored jobs must reach this URL for pings.
#   - Jobs on same Tailscale network → acc-tailscale works
#   - Jobs on public servers / cloud providers → need acc-public
#   - Internal-only infrastructure → acc-local or acc-private
# Default acc-tailscale assumes you run jobs on Tailscale-reachable hosts.
APP_TRAEFIK_ACCESS=acc-tailscale
# Security: sec-0 (none) to sec-5 (maximum).
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=8000
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# healthchecks/healthchecks (https://hub.docker.com/r/healthchecks/healthchecks)
APP_TAG=v3.13

# --- Containers ---
CONTAINER_NAME_APP=${COMPOSE_PROJECT_NAME}-app

# --- Healthchecks Configuration ---
# Display name in UI and email subjects.
HC_SITE_NAME=Healthchecks
# Open self-service signup (True/False). For private instance: False.
HC_REGISTRATION_OPEN=False
# Django SECRET_KEY — generate with:
#   openssl rand -base64 60 | tr -d '\n='
# Upstream does not support _FILE suffix for SECRET_KEY — stays in .env.
HC_SECRET_KEY=__REPLACE_ME__

# --- SMTP for alerts (required for notifications) ---
# Without SMTP, you will not receive alerts when checks fail.
HC_EMAIL_FROM=healthchecks@example.com
HC_SMTP_HOST=smtp-relay.example.com
HC_SMTP_PORT=587
HC_SMTP_USER=
HC_SMTP_PASSWORD=__REPLACE_ME__
HC_SMTP_USE_TLS=True

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC
