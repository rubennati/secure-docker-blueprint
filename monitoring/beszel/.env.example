# =============================================
# Beszel – Environment
# =============================================
# Copy this file to .env and adjust all values.
# NEVER commit the .env file.
# =============================================

COMPOSE_PROJECT_NAME=beszel

# --- Domain & Traefik ---
APP_TRAEFIK_HOST=beszel.example.com
APP_TRAEFIK_CERT_RESOLVER=cloudflare-dns
APP_TRAEFIK_TLS_OPTION=tls-aplus
# Host metrics expose system details — VPN-only default.
APP_TRAEFIK_ACCESS=acc-tailscale
APP_TRAEFIK_SECURITY=sec-3
APP_INTERNAL_PORT=8090
TRAEFIK_NETWORK=proxy-public

# --- Images ---
# henrygd/beszel (https://github.com/henrygd/beszel/pkgs/container/beszel)
# TODO: Beszel is pre-1.0 — pin to a specific release tag for stability.
APP_TAG=0.18.7

# --- Containers ---
CONTAINER_NAME_HUB=${COMPOSE_PROJECT_NAME}-hub
CONTAINER_NAME_AGENT=${COMPOSE_PROJECT_NAME}-agent

# --- App Configuration ---
# Hub's SSH public key for the local agent.
# Leave empty on first start. After the hub is up:
#   1. Open the UI, create the owner account
#   2. Click "+ Add System" (top right) → copy the SSH public key shown
#   3. Paste the FULL key including the "ssh-ed25519" type prefix:
#      AGENT_KEY=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA...
#      (not just the base64 part — the type prefix is required)
#   4. Run: docker compose up -d agent
AGENT_KEY=
# Optional: comma-separated mount points the agent should report on
# beyond the root FS. Example: /mnt/nas,/var/lib/docker
EXTRA_FILESYSTEMS=

# --- Timezone ---
# Examples: UTC, Europe/Berlin, Europe/Vienna, America/New_York
TZ=UTC
